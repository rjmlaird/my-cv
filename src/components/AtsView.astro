---
import * as api from "@/lib/api";

const {
  getLanguages,
  getProfile,
  getExperience,
  getEducation,
  getTeaching,
  getAwards,
  getSkills,
  getCertifications,
  getMemberships,
  getVolunteering,
  getProjects,
} = api;

const [experienceData, educationData, skillsData, certificationsData, membershipsData, awardsData, volunteeringData, languagesData, projectsData] =
  await Promise.all([
    getExperience(),
    getEducation(),
    getSkills(),
    getCertifications(),
    getMemberships(),
    getAwards(),
    getVolunteering(),
    getLanguages(),
    getProjects(),
  ]);

const profile = await getProfile();
const teaching = await getTeaching();

const experience = Array.isArray(experienceData) ? experienceData : [];
const education = Array.isArray(educationData) ? educationData : [];
const volunteering = Array.isArray(volunteeringData) ? volunteeringData : [];
const projects = Array.isArray(projectsData) ? projectsData : [];

// getSkills() already returns Record<string, SkillGroup>.
const skillsGroups = skillsData && typeof skillsData === "object" ? Object.values(skillsData) : [];

const certsArr = Array.isArray(certificationsData) ? certificationsData : [];
const membershipsArr = Array.isArray(membershipsData) ? membershipsData : [];
const awardsArr = Array.isArray(awardsData) ? awardsData : [];
const languagesArr = Array.isArray(languagesData) ? languagesData : [];

const skillsFlat = skillsGroups
  .map((g: any) => (Array.isArray(g.keywords) ? g.keywords.join(", ") : ""))
  .filter(Boolean)
  .join(", ");

const certsFlat = certsArr
  .map((g) => `${g.title ?? ""}: ${Array.isArray(g.items) ? g.items.map((i) => i.label ?? String(i)).join(", ") : ""}`)
  .filter((s) => s.trim().length > 1)
  .join(". ");

const membershipsFlat = membershipsArr
  .map((group: any) =>
    group && typeof group === "object" && Array.isArray(group.items)
      ? `${group.title ?? ""}: ${group.items
          .map((item: any) => [item.organisation, item.role].filter(Boolean).join(" — "))
          .filter(Boolean)
          .join(", ")}`
      : ""
  )
  .filter(Boolean)
  .join(". ");

const languagesFlat = languagesArr
  .map((l: any) => `${l.name ?? l.label ?? ""}${l.level ? ` (${l.level})` : ""}`)
  .filter(Boolean)
  .join("; ");

const volunteeringFlat = volunteering
  .map((g: any) =>
    g && typeof g === "object" && Array.isArray(g.items)
      ? `${g.title ?? ""}: ${g.items
          .map((i: any) => [i.organisation, i.role].filter(Boolean).join(" — "))
          .filter(Boolean)
          .join(", ")}`
      : ""
  )
  .filter(Boolean)
  .join(". ");

function formatAward(award: (typeof awardsArr)[number]): string {
  if (typeof award === "string") return award;
  return [award.title, award.issuer ? `— ${award.issuer}` : "", award.year ? `(${award.year})` : ""]
    .filter(Boolean)
    .join(" ");
}
---

<div id="ats-view">
  <h1>{profile.name}</h1>
  <p class="ats-meta">
    Director of Green Orbit Digital · {profile.credentials}<br />
    Email: rjmlaird@gmail.com &nbsp;|&nbsp; LinkedIn: linkedin.com/in/rjmlaird87 &nbsp;|&nbsp;
    GitHub: github.com/rjmlaird &nbsp;|&nbsp; ORCID: 0000-0002-5992-684X
  </p>

  <h2>Summary</h2>
  {Array.isArray(profile.summary) ? profile.summary.map((p) => <p>{p}</p>) : null}

  <h2>Core Skills</h2>
  <p>{Array.isArray(profile.tags) ? profile.tags.join(", ") : ""}. Technical: {skillsFlat}.</p>

  <h2>Experience</h2>
  {experience.map((role) => (
    <div class="ats-entry">
      <strong>{role.role}</strong> — {role.organisation ?? "Self-employed"}
      <span class="ats-meta">
        ({role.startDate}
        {role.endDate ? ` to ${role.endDate}` : role.current ? " to present" : ""})
      </span>
      <p>{role.summary}</p>
      {Array.isArray(role.responsibilities) && role.responsibilities.length > 0 && (
        <ul>
          {role.responsibilities.map((item) => <li>{item}</li>)}
        </ul>
      )}
    </div>
  ))}

  <h2>Education</h2>
  <ul>
    {education.map((item) => (
      <li>
        {item.qualification} — {item.institution}
        {item.field ? `, ${item.field}` : ""}
        {item.startDate ? ` (${item.startDate}${item.endDate ? ` – ${item.endDate}` : ""})` : ""}
      </li>
    ))}
  </ul>

  {projects.length > 0 && (
    <>
      <h2>Projects</h2>
      <ul>
        {projects.map((project) => (
          <li>
            {project.title}
            {project.description ? ` — ${project.description}` : ""}
            {Array.isArray(project.toolsTech) && project.toolsTech.length > 0
              ? ` (${project.toolsTech.join(", ")})`
              : ""}
          </li>
        ))}
      </ul>
    </>
  )}

  <h2>Teaching</h2>
  <p class="ats-meta">{teaching.org}</p>
  <ul>
    {Array.isArray(teaching.items) ? teaching.items.map((item) => <li>{item}</li>) : null}
  </ul>

  <h2>Certifications</h2>
  <p>{certsFlat}.</p>

  <h2>Professional Memberships</h2>
  <p>{membershipsFlat}.</p>

  <h2>Languages</h2>
  <p>{languagesFlat}.</p>

  <h2>Volunteering</h2>
  <p>{volunteeringFlat}.</p>

  <h2>Awards</h2>
  <p>{awardsArr.map(formatAward).join("; ")}.</p>
</div>
