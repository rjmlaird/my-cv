---
import * as api from '@/lib/api';
import { languages } from '@/data/languages';
import { profile } from '@/data/profile';
import { research, teaching, awards as localAwards } from '@/data/awards';

const {
  getExperience,
  getEducation,
  getSkills,
  getCertifications,
  getMemberships,
  getAwards,
} = api;

const experienceData = await getExperience();
const educationData = await getEducation();
const skillsData = await getSkills();
const certificationsData = await getCertifications();
const membershipsData = await getMemberships();
const awardsData = await getAwards();

const experience = Array.isArray(experienceData) ? experienceData : [];
const education = Array.isArray(educationData) ? educationData : [];

// getSkills() already returns Record<string, SkillGroup> — unwrap directly.
const skillsGroups = skillsData && typeof skillsData === 'object' ? Object.values(skillsData) : [];

const certsArr = Array.isArray(certificationsData) ? certificationsData : [];
const membershipsArr = Array.isArray(membershipsData) ? (membershipsData as any[]) : [];
const awardsArr = Array.isArray(awardsData) && awardsData.length > 0 ? awardsData : localAwards;

const skillsFlat = skillsGroups
  .map((g: any) => (Array.isArray(g.keywords) ? g.keywords.join(', ') : ''))
  .filter(Boolean)
  .join(', ');

const certsFlat = certsArr
  .map((g) => `${g.title ?? ''}: ${Array.isArray(g.items) ? g.items.map((i) => i.label ?? String(i)).join(', ') : ''}`)
  .filter((s) => s.trim().length > 1)
  .join('. ');

const membershipsFlat = membershipsArr
  .map((m) => (typeof m === 'string' ? m : [m.organisation, m.role].filter(Boolean).join(' — ')))
  .filter(Boolean)
  .join('; ');

const languagesFlat = languages.map((l) => `${l.name} (${l.level})`).join('; ');

function formatAward(award: (typeof awardsArr)[number]): string {
  if (typeof award === 'string') return award;
  return [award.title, award.issuer ? `— ${award.issuer}` : '', award.date ? `(${award.date})` : '']
    .filter(Boolean)
    .join(' ');
}
---

<div id="ats-view">
  <h1>{profile.name}</h1>
  <p class="ats-meta">
    Director of Green Orbit Digital · {profile.credentials}<br />
    Email: rjmlaird@gmail.com &nbsp;|&nbsp; LinkedIn: linkedin.com/in/rjmlaird87 &nbsp;|&nbsp;
    GitHub: github.com/rjmlaird &nbsp;|&nbsp; ORCID: 0000-0002-5992-684X
  </p>

  <h2>Summary</h2>
  {profile.summary.map((p) => <p>{p}</p>)}

  <h2>Core Skills</h2>
  <p>{profile.tags.join(', ')}. Technical: {skillsFlat}.</p>

  <h2>Experience</h2>
  {experience.map((role) => (
    <div class="ats-entry">
      <strong>{role.role}</strong> — {role.organisation ?? 'Self-employed'}
      <span class="ats-meta">
        ({role.startDate}
        {role.endDate ? ` to ${role.endDate}` : role.current ? ' to present' : ''})
      </span>
      <p>{role.summary}</p>
      {Array.isArray(role.responsibilities) && role.responsibilities.length > 0 && (
        <ul>
          {role.responsibilities.map((item) => <li>{item}</li>)}
        </ul>
      )}
    </div>
  ))}

  <h2>Education</h2>
  <ul>
    {education.map((item) => (
      <li>
        {item.qualification} — {item.institution}
        {item.field ? `, ${item.field}` : ''}
        {item.startDate ? ` (${item.startDate}${item.endDate ? ` – ${item.endDate}` : ''})` : ''}
      </li>
    ))}
  </ul>

  <h2>Research</h2>
  {research.paragraphs.map((p) => <p>{p}</p>)}

  <h2>Teaching</h2>
  <p class="ats-meta">{teaching.org}</p>
  <ul>
    {teaching.items.map((item) => <li>{item}</li>)}
  </ul>

  <h2>Certifications</h2>
  <p>{certsFlat}.</p>

  <h2>Professional Memberships</h2>
  <p>{membershipsFlat}.</p>

  <h2>Languages</h2>
  <p>{languagesFlat}.</p>

  <h2>Awards</h2>
  <p>{awardsArr.map(formatAward).join('; ')}.</p>
</div>
