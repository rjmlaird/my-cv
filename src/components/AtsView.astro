---
import * as api from '@/lib/api';
import { languages } from '@/data/languages';

const {
  getProfile,
  getExperience,
  getEducation,
  getSkills,
  getCertifications,
  getMemberships,
  getAwards,
} = api;

const profile = await getProfile();
const experienceData = await getExperience();
const educationData = await getEducation();
const skillsData = await getSkills();
const certificationsData = await getCertifications();
const membershipsData = await getMemberships();
const awardsData = await getAwards();

const experience = Array.isArray(experienceData)
  ? experienceData
  : Array.isArray(experienceData?.experience)
    ? experienceData.experience
    : [];

const education = Array.isArray(educationData)
  ? educationData
  : Array.isArray(educationData?.education)
    ? educationData.education
    : [];

const skillsGroups = Array.isArray(skillsData)
  ? skillsData
  : skillsData && typeof skillsData === 'object' && !Array.isArray(skillsData) && 'skills' in skillsData
    ? Object.values(skillsData.skills)
    : [];

const certsArr = Array.isArray(certificationsData) ? certificationsData : [];
const membershipsArr = Array.isArray(membershipsData) ? membershipsData : [];
const awardsArr = Array.isArray(awardsData) ? awardsData : [];

const skillsFlat = skillsGroups
  .map((g) => (Array.isArray(g.items) ? g.items.join(', ') : ''))
  .filter(Boolean)
  .join(', ');

const certsFlat = certsArr
  .map((g) => `${g.title ?? ''}: ${Array.isArray(g.items) ? g.items.map((i) => i.label ?? String(i)).join(', ') : ''}`)
  .filter((s) => s.trim().length > 1)
  .join('. ');

const membershipsFlat = membershipsArr
  .map((g) => (Array.isArray(g.items) ? g.items.join('; ') : ''))
  .filter(Boolean)
  .join('; ');

const languagesFlat = languages.map((l) => `${l.name} (${l.level})`).join('; ');
---

---

<div id="ats-view">
  <h1>{profile.name}</h1>
  <p class="ats-meta">
    Director of Green Orbit Digital · Chartered Marketer (CMktr) · {profile.credentials}<br />
    Email: rjmlaird@gmail.com &nbsp;|&nbsp; LinkedIn: linkedin.com/in/rjmlaird87 &nbsp;|&nbsp;
    GitHub: github.com/rjmlaird &nbsp;|&nbsp; ORCID: 0000-0002-5992-684X
  </p>

  <h2>Summary</h2>
  {Array.isArray(profile.summary) ? profile.summary.map((p) => <p>{p}</p>) : null}

  <h2>Core Skills</h2>
  <p>{Array.isArray(profile.tags) ? profile.tags.join(', ') : ''}. Technical: {skillsFlat}.</p>

  <h2>Experience</h2>
  {experience.map((role) => (
    <div class="ats-entry">
      <strong>{role.role}</strong> — {role.organisation ?? role.organization ?? role.org}
      <span class="ats-meta">
        ({role.startDate}
        {role.endDate ? ` to ${role.endDate}` : role.current ? ' to present' : ''})
      </span>
      <p>{role.summary}</p>
      {Array.isArray(role.responsibilities) && role.responsibilities.length > 0 && (
        <ul>
          {role.responsibilities.map((item) => <li>{item}</li>)}
        </ul>
      )}
    </div>
  ))}

  <h2>Education</h2>
  <ul>
    {education.map((item) => (
      <li>{item.title ?? item.role ?? item.name} — {item.org ?? item.organisation}, {item.dates ?? item.startDate}</li>
    ))}
  </ul>

  <h2>Certifications</h2>
  <p>{certsFlat}.</p>

  <h2>Professional Memberships</h2>
  <p>{membershipsFlat}.</p>

  <h2>Languages</h2>
  <p>{languagesFlat}.</p>

  <h2>Awards</h2>
  <p>{awardsArr.join('; ')}.</p>
</div>
