---
import { getAwards, getExperience, getEducation } from "@/lib/api";
import { awardItemSchema, type AwardItem } from "@/lib/schemas/award.schema";
import { educationItemSchema, type EducationItem } from "@/lib/schemas/education.schema";
import { experienceItemSchema, type ExperienceItem } from "@/lib/schemas/experience.schema";

const rawAwards = await getAwards();
const rawExperience = await getExperience();
const rawEducation = await getEducation();

const awards: AwardItem[] = Array.isArray(rawAwards) ? rawAwards.map((item) => awardItemSchema.parse(item)) : [];
const experiences: ExperienceItem[] = Array.isArray(rawExperience) ? rawExperience.map((item) => experienceItemSchema.parse(item)) : [];
const educations: EducationItem[] = Array.isArray(rawEducation) ? rawEducation.map((item) => educationItemSchema.parse(item)) : [];

const getExperienceMatches = (award: AwardItem) => {
  const ids = new Set((award.relatedExperience ?? []).map((id) => String(id).trim()));
  return experiences.filter((item) => ids.has(String(item.id).trim()));
};

const getEducationMatches = (award: AwardItem) => {
  const ids = new Set((award.relatedEducation ?? []).map((id) => String(id).trim()));
  return educations.filter((item) => ids.has(String(item.id).trim()));
};

const getExperienceLabel = (item: ExperienceItem) => item.role || item.id;
const getExperienceOrg = (item: ExperienceItem) => {
  const org = item.organisation;
  if (typeof org === 'string') return org;
  return (org && typeof org === 'object' && 'name' in org) ? org.name : "";
};

const getEducationLabel = (item: EducationItem) => item.qualification || item.role || item.institution || item.id;
const getEducationOrg = (item: EducationItem) => item.institution || "";

const hasMoreDetail = (award: AwardItem) => 
  (award.session_title || award.project || award.category || award.client || award.programme || award.value || award.instrument || award.duration || award.research_area || award.funded_by?.length || award.items?.length || getExperienceMatches(award).length > 0 || getEducationMatches(award).length > 0);
---

<section id="awards" aria-labelledby="awards-heading">
  <p class="eyebrow">Recognition</p>
  <h2 id="awards-heading">Awards</h2>

  <div class="award-list">
    {awards.map((award) => {
      const relatedExperience = getExperienceMatches(award);
      const relatedEducation = getEducationMatches(award);

      return (
        <article id={`${award.id}`} class="role-item award-item">
          <div class="role-header">
            <div>
              <span class="role-title">{award.title}</span>
              {award.issuer ? <> · <span class="role-org">{award.issuer}</span></> : null}
              {award.year ? <> · <span class="role-location">{award.year}</span></> : null}
            </div>
          </div>

          {hasMoreDetail(award) ? (
            <details class="more-detail">
              <summary>More detail</summary>

              {/* Award Specific Details */}
              <ul class="role-list">
                {award.session_title && <li>Session: {award.session_title}</li>}
                {award.project && <li>Project: {award.project}</li>}
                {award.category && <li>Category: {award.category}</li>}
                {award.client && <li>Client: {award.client}</li>}
                {award.programme && <li>Programme: {award.programme}</li>}
                {award.value && <li>Value: {award.value}</li>}
                {award.instrument && <li>Instrument: {award.instrument}</li>}
                {award.duration && <li>Duration: {award.duration}</li>}
                {award.research_area && <li>Research area: {award.research_area}</li>}
                {award.funded_by?.length ? <li>Funded by: {award.funded_by.join(", ")}</li> : null}
              </ul>

              {relatedExperience.length > 0 && (
                <>
                  <h4 class="role-subheading">Related experience</h4>
                  <ul class="role-list">
                    {relatedExperience.map((item) => (
                      <li>
                        <strong>{getExperienceLabel(item)}</strong>
                        {getExperienceOrg(item) ? <> · {getExperienceOrg(item)}</> : null}
                      </li>
                    ))}
                  </ul>
                </>
              )}

              {relatedEducation.length > 0 && (
                <>
                  <h4 class="role-subheading">Related education</h4>
                  <ul class="role-list">
                    {relatedEducation.map((item) => (
                      <li>
                        <strong>{getEducationLabel(item)}</strong>
                        {getEducationOrg(item) ? <> · {getEducationOrg(item)}</> : null}
                      </li>
                    ))}
                  </ul>
                </>
              )}
            </details>
          ) : null}
        </article>
      );
    })}
  </div>
</section>