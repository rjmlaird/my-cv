---
import { getAwards, getExperience, getEducation } from "@/lib/api";
import { awardItemSchema, type AwardItem } from "@/lib/schemas/award.schema";
import { educationItemSchema, type EducationItem } from "@/lib/schemas/education.schema";
import { experienceItemSchema, type ExperienceItem } from "@/lib/schemas/experience.schema";

const rawAwards = await getAwards();
const rawExperience = await getExperience();
const rawEducation = await getEducation();

const awards: AwardItem[] = Array.isArray(rawAwards)
  ? rawAwards.map((item) => awardItemSchema.parse(item))
  : [];

const experiences: ExperienceItem[] = Array.isArray(rawExperience)
  ? rawExperience.map((item) => experienceItemSchema.parse(item))
  : [];

const educations: EducationItem[] = Array.isArray(rawEducation)
  ? rawEducation.map((item) => educationItemSchema.parse(item))
  : [];

const cleanText = (value: unknown) =>
  value === null || value === undefined ? "" : String(value).trim();

const formatLine = (...parts: Array<string | number | undefined | null>) =>
  parts
    .filter((part) => part !== undefined && part !== null && String(part).trim() !== "")
    .join(" • ");

const listText = (items?: string[]) =>
  Array.isArray(items) && items.length > 0 ? items.join(", ") : "";

const getPrimaryContext = (award: AwardItem) =>
  award.event ||
  award.session_title ||
  award.project ||
  award.programme ||
  award.research_area ||
  award.instrument ||
  award.location ||
  award.value ||
  "";

const getSecondaryContext = (award: AwardItem) => {
  if (award.type) return cleanText(award.type).replace(/_/g, " ");
  if (award.role) return formatLine("Role", award.role);
  if (award.client) return formatLine("Client", award.client);
  if (award.category) return formatLine("Category", award.category);
  if (award.duration) return formatLine("Duration", award.duration);
  return "";
};

const getDetails = (award: AwardItem) => {
  const details: string[] = [];

  if (award.session_title) details.push(`Session: ${award.session_title}`);
  if (award.project) details.push(`Project: ${award.project}`);
  if (award.category) details.push(`Category: ${award.category}`);
  if (award.client) details.push(`Client: ${award.client}`);
  if (award.programme) details.push(`Programme: ${award.programme}`);
  if (award.value) details.push(`Value: ${award.value}`);
  if (award.instrument) details.push(`Instrument: ${award.instrument}`);
  if (award.duration) details.push(`Duration: ${award.duration}`);
  if (award.research_area) details.push(`Research area: ${award.research_area}`);
  if (listText(award.funded_by)) details.push(`Funded by: ${listText(award.funded_by)}`);
  if (listText(award.items)) details.push(`Included: ${listText(award.items)}`);

  return details;
};

const getExperienceMatches = (award: AwardItem) => {
  const ids = new Set((award.relatedExperience ?? []).map((id) => String(id).trim()));
  return experiences.filter((item) => ids.has(String(item.id).trim()));
};

const getEducationMatches = (award: AwardItem) => {
  const ids = new Set((award.relatedEducation ?? []).map((id) => String(id).trim()));
  return educations.filter((item) => ids.has(String(item.id).trim()));
};

const getExperienceLabel = (item: ExperienceItem) => item.role || item.id;
const getExperienceOrg = (item: ExperienceItem) => item.organisation || "";

const getEducationLabel = (item: EducationItem) =>
  item.qualification || item.role || item.institution || item.id;

const getEducationOrg = (item: EducationItem) => item.institution || "";
---

<section id="awards" aria-labelledby="awards-heading">
  <p class="eyebrow">Recognition</p>
  <h2 id="awards-heading">Awards</h2>

  <div class="award-list">
    {awards.map((award) => {
      const primaryContext = getPrimaryContext(award);
      const secondaryContext = getSecondaryContext(award);
      const details = getDetails(award);
      const relatedExperience = getExperienceMatches(award);
      const relatedEducation = getEducationMatches(award);

      return (
        <article id={`award-${award.id}`} class="role-item award-item">
          <div class="role-header">
            <div>
              <span class="role-title">{award.title}</span>
              {award.issuer ? <> · <span class="role-org">{award.issuer}</span></> : null}
              {award.year ? <> · <span class="role-location">{award.year}</span></> : null}
            </div>
          </div>

          {primaryContext ? <p class="award-primary">{primaryContext}</p> : null}
          {secondaryContext ? <p class="award-secondary">{secondaryContext}</p> : null}
          {award.description ? <p class="award-desc">{award.description}</p> : null}

          {details.length > 0 ? (
            <ul class="award-details" aria-label={`${award.title} details`}>
              {details.map((detail) => (
                <li>{detail}</li>
              ))}
            </ul>
          ) : null}

          {relatedExperience.length > 0 ? (
            <div class="award-related">
              <p class="award-meta-heading">Related experience</p>
              <ul class="award-related-list">
                {relatedExperience.map((item) => (
                  <li>
                    <strong>{getExperienceLabel(item)}</strong>
                    {getExperienceOrg(item) ? <> · {getExperienceOrg(item)}</> : null}
                  </li>
                ))}
              </ul>
            </div>
          ) : null}

          {relatedEducation.length > 0 ? (
            <div class="award-related">
              <p class="award-meta-heading">Related education</p>
              <ul class="award-related-list">
                {relatedEducation.map((item) => (
                  <li>
                    <strong>{getEducationLabel(item)}</strong>
                    {getEducationOrg(item) ? <> · {getEducationOrg(item)}</> : null}
                  </li>
                ))}
              </ul>
            </div>
          ) : null}
        </article>
      );
    })}
  </div>
</section>
