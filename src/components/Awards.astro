---
import { getAwards } from '@/lib/api';

const rawAwards = await getAwards();
const awards = Array.isArray(rawAwards) ? rawAwards : [];

function formatAward(award: (typeof awards)[number]): string {
  if (typeof award === 'string') return award;
  const parts = [award.title, award.issuer ? `— ${award.issuer}` : '', award.date ? `(${award.date})` : ''];
  return parts.filter(Boolean).join(' ');
}
---

<section id="awards" aria-labelledby="awards-heading">
  <p class="eyebrow">Recognition</p>
  <h2 id="awards-heading">Awards</h2>

  <ul class="award-list">
    {awards.map((award) => (
      <li>
        {formatAward(award)}
        {typeof award !== 'string' && award.description ? <span class="award-desc"> — {award.description}</span> : null}
      </li>
    ))}
  </ul>
</section>
