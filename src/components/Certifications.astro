---
import { getCertifications } from "@/lib/api";

type CertItem = {
  id: string;
  name: string;
  url?: string;
  badgeUrl?: string;
  issuer?: string;
};

type CertGroup = {
  issuer: string;
  items: CertItem[];
};

const certifications = (await getCertifications()) ?? [];

const grouped = certifications.reduce<Record<string, CertItem[]>>((acc, item) => {
  const issuer = String(item.issuer ?? "Other").trim() || "Other";

  const normalizedItem: CertItem = {
    id: String(item.id ?? ""),
    name: String(item.name ?? ""),
    url: item.url ?? item.badgeUrl,
    badgeUrl: item.badgeUrl,
    issuer: item.issuer,
  };

  (acc[issuer] ||= []).push(normalizedItem);
  return acc;
}, {});

const orderedCertifications: CertGroup[] = Object.entries(grouped)
  .map(([issuer, items]) => ({
    issuer,
    items: [...items].sort((a, b) =>
      String(a.name ?? "").localeCompare(String(b.name ?? "")),
    ),
  }))
  .sort((a, b) => a.issuer.localeCompare(b.issuer));

const columns = 3;
const size = Math.max(1, Math.ceil(orderedCertifications.length / columns));

const certColumns = [
  orderedCertifications.slice(0, size),
  orderedCertifications.slice(size, size * 2),
  orderedCertifications.slice(size * 2),
].filter((column) => column.length > 0);

const cleanLabel = (value: string) =>
  String(value ?? "")
    .replace(/\s*[\r\n]+\s*/g, " ")
    .replace(/\s*–\s*/g, " – ")
    .replace(/\s+/g, " ")
    .trim();
---

<section id="certifications" aria-labelledby="cert-heading">
  <p class="eyebrow">Credentials</p>
  <h2 id="cert-heading">Certifications</h2>

  {certColumns.length > 0 ? (
    <div class="cert-columns">
      {certColumns.map((column) => (
        <div class="cert-column">
          {column.map((group) => (
            <article>
              <h3 class="role-subheading">{group.issuer}</h3>

              <ul class="cert-list clean-list" aria-label={group.issuer}>
                {group.items.map((item) => (
                  <li class="cert-item">
                    {item.url ? (
                      <a href={item.url} target="_blank" rel="noopener noreferrer">
                        {cleanLabel(item.name)}
                      </a>
                    ) : (
                      cleanLabel(item.name)
                    )}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      ))}
    </div>
  ) : (
    <p>No certifications found.</p>
  )}
</section>

<style>
  .cert-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    align-items: start;
  }

  .cert-column {
    display: grid;
    gap: 1.5rem;
    align-content: start;
  }

  .cert-list {
    display: grid;
    gap: 0.5rem;
  }

  .clean-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .clean-list li {
    margin: 0;
  }

  .cert-item {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .cert-item a {
    color: inherit;
    text-decoration: none;
  }

  .cert-item a:hover {
    text-decoration: underline;
  }

  @media (max-width: 64rem) {
    .cert-columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 48rem) {
    .cert-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
