---
import { getCertifications } from "@/lib/api";
import { getCdnUrl } from "@/lib/cdn";

// 1. Fetch raw certification data
const rawCertifications = await getCertifications().catch(() => []);

// 2. Resolve dynamic links
// We map over the certifications and resolve the CDN URL using the cdnId
const certifications = await Promise.all(
  rawCertifications.map(async (cert) => ({
    ...cert,
    resolvedUrl: cert.cdnId ? await getCdnUrl(cert.cdnId) : undefined,
  }))
);

// 3. Define Types
type CertItem = {
  id: string;
  name: string;
  url?: string;
  issuer: string;
};

type CertGroup = {
  issuer: string;
  items: CertItem[];
};

// 4. Grouping Logic
const grouped = certifications.reduce<Record<string, CertItem[]>>((acc, item) => {
  const issuer = (item.issuer ?? "Other").trim() || "Other";

  const normalizedItem: CertItem = {
    id: String(item.id ?? ""),
    name: String(item.name ?? ""),
    url: item.resolvedUrl,
    issuer: issuer,
  };

  if (!acc[issuer]) acc[issuer] = [];
  acc[issuer].push(normalizedItem);
  return acc;
}, {});

// 5. Ordering and Layout Logic
const orderedCertifications: CertGroup[] = Object.entries(grouped)
  .map(([issuer, items]) => ({
    issuer,
    items: [...items].sort((a, b) => a.name.localeCompare(b.name)),
  }))
  .sort((a, b) => a.issuer.localeCompare(b.issuer));

const columns = 3;
const size = Math.max(1, Math.ceil(orderedCertifications.length / columns));

const certColumns = [
  orderedCertifications.slice(0, size),
  orderedCertifications.slice(size, size * 2),
  orderedCertifications.slice(size * 2),
].filter((column) => column.length > 0);

const cleanLabel = (value: string) =>
  value
    .replace(/\s*[\r\n]+\s*/g, " ")
    .replace(/\s*–\s*/g, " – ")
    .replace(/\s+/g, " ")
    .trim();
---

<section id="certifications" aria-labelledby="cert-heading">
  <p class="eyebrow">Credentials</p>
  <h2 id="cert-heading">Certifications</h2>

  {certColumns.length > 0 ? (
    <div class="cert-columns">
      {certColumns.map((column) => (
        <div class="cert-column">
          {column.map((group) => (
            <article>
              <h3 class="role-subheading">{group.issuer}</h3>
              <ul class="cert-list clean-list" aria-label={group.issuer}>
                {group.items.map((item) => (
                  <li class="cert-item">
                    {item.url ? (
                      <a href={item.url} target="_blank" rel="noopener noreferrer">
                        {cleanLabel(item.name)}
                      </a>
                    ) : (
                      <span>{cleanLabel(item.name)}</span>
                    )}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      ))}
    </div>
  ) : (
    <p>No certifications found.</p>
  )}
</section>

<style>
  .cert-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    align-items: start;
  }

  .cert-column {
    display: grid;
    gap: 1.5rem;
    align-content: start;
  }

  .cert-list {
    display: grid;
    gap: 0.5rem;
  }

  .clean-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cert-item {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .cert-item a {
    color: var(--text-link); /* Ensure you have this variable or swap to your brand color */
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cert-item a:hover {
    text-decoration: underline;
    opacity: 0.8;
  }

  @media (max-width: 64rem) {
    .cert-columns { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 48rem) {
    .cert-columns { grid-template-columns: 1fr; }
  }
</style>