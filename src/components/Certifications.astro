---
import certificationsData from "../data/certifications.json";

const { mode = "human" } = Astro.props;

// Normalise input
const certifications = Array.isArray(certificationsData?.certifications)
  ? certificationsData.certifications
  : [];

const isATS = mode === "ats";

// ATS flattened stream (clean keyword-style output)
const atsStream = certifications
  .flatMap((c) => c?.items ?? [])
  .filter((v) => typeof v === "string" && v.trim().length > 0)
  .map((v) => v.trim())
  .sort((a, b) => a.localeCompare(b));
---

<section class="certifications">

  {isATS ? (
    <div class="ats-mode text-xs text-gray-700 leading-relaxed">
      {atsStream.length > 0 ? (
        <p>{atsStream.join(" · ")}</p>
      ) : (
        <p class="text-gray-400">No certification data available</p>
      )}
    </div>
  ) : (
    <div class="human-mode space-y-6">
      {certifications.length > 0 ? (
        certifications.map((certGroup) => (
          <article class="cert-group break-inside-avoid">
            <header class="mb-2">
              <h3 class="font-semibold text-base">
                {certGroup.organisation ?? "Organisation"}
              </h3>

              {certGroup.url && (
                <p class="text-xs text-gray-500">
                  {certGroup.url}
                </p>
              )}
            </header>

            {Array.isArray(certGroup.items) && certGroup.items.length > 0 ? (
              <ul class="space-y-1 text-sm text-gray-700">
                {certGroup.items.map((item) => (
                  <li class="cert-item">
                    {item}
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-sm text-gray-400">
                No certifications listed
              </p>
            )}
          </article>
        ))
      ) : (
        <p class="text-sm text-gray-500">No certifications available</p>
      )}
    </div>
  )}
</section>

<style>

  .cert-item {
    @apply leading-snug;
  }
</style>