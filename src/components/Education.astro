---
import { getEducation } from "@/lib/api";
import type { EducationItem } from "@/lib/schemas/education.schema";

const education = (await getEducation()) ?? [];
---

<section id="education" aria-labelledby="education-heading">
  <p class="eyebrow">Academic background</p>
  <h2 id="education-heading">Education</h2>

  {education.length > 0
    ? education.map((item: EducationItem) => {
        const achievements = Array.isArray(item.achievements) ? item.achievements : [];

        return (
          <div class="edu-item">
            <div class="role-header">
              <div>
                <span class="role-title">{item.qualification}</span>
              </div>
              <time class="role-dates">
                {item.startDate} — {item.endDate || "Present"}
              </time>
            </div>

            <p class="role-org">
              {item.institution}
              {item.field ? ` · ${item.field}` : ""}
            </p>

            {item.description ? <p>{item.description}</p> : null}

            {achievements.length > 0 ? (
              <ul class="role-list">
                {achievements.map((achievement) => <li>{achievement}</li>)}
              </ul>
            ) : null}
          </div>
        );
      })
    : null}
</section>
