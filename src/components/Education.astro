---
import { getEducation, getProjects } from "@/lib/api";
import { resolveSkillTags } from "@/lib/skills";
import type { EducationItem } from "@/lib/schemas/education.schema";

// 1. Fetch and process data
const education = (await getEducation()) ?? [];
const allProjects = (await getProjects()) ?? [];

// Create a map for quick lookup: slug -> title
const projectMap = new Map(allProjects.map((p) => [p.slug, p.title]));

const formatDate = (value?: string | null) => {
  if (!value) return "";
  const [year, month] = value.split("-");
  if (!year) return value;
  if (!month) return year;
  return new Intl.DateTimeFormat("en-GB", {
    month: "short",
    year: "numeric",
  }).format(new Date(Number(year), Number(month) - 1, 1));
};

// 2. Define 'rows' here, inside the frontmatter
const rows = await Promise.all(
  education.map(async (item: EducationItem) => ({
    item,
    skills: await resolveSkillTags(item.skills),
  })),
);

const hasMoreDetail = (item: EducationItem) =>
  Boolean(
    item.keyActivities?.length ||
      item.achievements?.length ||
      item.articles?.length ||
      item.talks?.length ||
      item.relatedAwards?.length ||
      item.relatedCertifications?.length ||
      item.projects?.length, // Added check for projects
  );
---

<section id="education" aria-labelledby="education-heading">
  <p class="eyebrow">Academic background</p>
  <h2 id="education-heading">Education</h2>

  {rows.map(({ item, skills }) => {
    const title = item.qualification || item.role || "Education";
    const startDate = formatDate(item.startDate);
    const endDate = item.current ? "Present" : formatDate(item.endDate);
    
    // Normalized location: City, Country
    const location = [item.city, item.country].filter(Boolean).join(", ");

    return (
      <article id={`edu-${item.id}`} class="role-item edu-item">
        <div class="role-header">
          <div>
            <span class="role-title">{title}</span>
            {item.institution ? <>{" · "}<span class="role-org">{item.institution}</span></> : null}
            {location ? <>{" · "}<span class="role-location">{location}</span></> : null}
          </div>

          {(startDate || endDate) ? (
            <time class="role-dates">
              {startDate}
              {startDate && endDate ? " — " : ""}
              {endDate}
            </time>
          ) : null}
        </div>

        {item.summary ? <p class="education-summary">{item.summary}</p> : null}

        {skills.length > 0 ? (
          <ul class="pill-list" aria-label="Skills">
            {skills.map((skill) => (
              <li class="pill">
                {skill.resolved ? <a href={skill.href}>{skill.label}</a> : skill.label}
              </li>
            ))}
          </ul>
        ) : null}

        {hasMoreDetail(item) ? (
          <details class="more-detail">
            <summary>More detail</summary>
            
            {item.projects?.length ? (
                <>
                  <h4 class="role-subheading">Projects</h4>
                  <ul class="role-list">
                    {item.projects.map((slug) => {
                      const title = projectMap.get(slug) || slug;
                      return (
                        <li>
                          <a href={`https://rjmlaird.co.uk/projects/${slug}`} target="_blank" rel="noopener noreferrer">
                            {title}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </>
              ) : null}

            {item.keyActivities?.length ? (
              <>
                <h4 class="role-subheading">Key Activities</h4>
                <ul class="role-list">{item.keyActivities.map((r) => <li>{r}</li>)}</ul>
              </>
            ) : null}
            {item.achievements?.length ? (
              <>
                <h4 class="role-subheading">Achievements</h4>
                <ul class="role-list">{item.achievements.map((a) => <li>{a}</li>)}</ul>
              </>
            ) : null}
          </details>
        ) : null}
      </article>
    );
  })}
</section>