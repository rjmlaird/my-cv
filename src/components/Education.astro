---
import { getCollection } from "astro:content";
import Institution from "./Institution.astro";

const institutePositions = (await getCollection("education")).sort(
  (a, b) => b.data.from.getTime() - a.data.from.getTime(),
);
---

<ul class="list-none pl-0 mb-0">
  {
    institutePositions.map(async (institutePosition) => {
      const { Content } = await institutePosition.render();
      return (
        <li class="pl-0 mb-6 last:mb-0">
          <Institution {...institutePosition.data}>
            <Content />
          </Institution>
        </li>
      );
    })
  }
</ul>
