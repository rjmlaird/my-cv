---
import { getEducation, getProjects } from "@/lib/api";
import { resolveSkillTags, resolveProjectRefs } from "@/lib/skills";
import type { EducationItem } from "@/lib/schemas/education.schema";

const education = (await getEducation()) ?? [];

let projects: Awaited<ReturnType<typeof getProjects>> = [];
try {
  projects = await getProjects();
} catch {
  projects = [];
}

const formatDate = (value?: string | null) => {
  if (!value) return "";
  const [year, month] = value.split("-");
  if (!year) return value;
  if (!month) return year;
  return new Intl.DateTimeFormat("en-GB", {
    month: "short",
    year: "numeric",
  }).format(new Date(Number(year), Number(month) - 1, 1));
};

const rows = await Promise.all(
  education.map(async (item: EducationItem) => ({
    item,
    skills: await resolveSkillTags(item.skills),
    projectRefs: resolveProjectRefs(item.projects, projects),
  })),
);

const hasMoreDetail = (item: EducationItem) =>
  Boolean(
    (item.responsibilities && item.responsibilities.length) ||
      (item.achievements && item.achievements.length) ||
      (item.articles && item.articles.length) ||
      (item.talks && item.talks.length) ||
      (item.certifications && item.certifications.length),
  );
---

<section id="education" aria-labelledby="education-heading">
  <p class="eyebrow">Academic background</p>
  <h2 id="education-heading">Education</h2>

  {rows.map(({ item, skills, projectRefs }) => {
    const title = item.qualification || item.role || "Education";
    const startDate = formatDate(item.startDate);
    const endDate = item.current ? "Present" : formatDate(item.endDate);
    const location = [item.city, item.country].filter(Boolean).join(", ");

    return (
      <article class="role-item edu-item">
        <div class="role-header">
          <div>
            <span class="role-title">{title}</span>
            {item.institution ? (
              <>
                {" · "}
                <span class="role-org">{item.institution}</span>
              </>
            ) : null}
            {item.field ? (
              <>
                {" · "}
                <span class="role-location">{item.field}</span>
              </>
            ) : null}
            {location ? (
              <>
                {" · "}
                <span class="role-location">{location}</span>
              </>
            ) : null}
          </div>

          {(startDate || endDate) ? (
            <time class="role-dates">
              {startDate}
              {startDate && endDate ? " — " : ""}
              {endDate}
            </time>
          ) : null}
        </div>

        {item.summary ? <p>{item.summary}</p> : null}

        {projectRefs.length > 0 ? (
          <ul class="pill-list" aria-label="Related projects">
            {projectRefs.map((ref) => (
              <li class="pill">{ref.resolved ? <a href={ref.href}>{ref.label}</a> : ref.label}</li>
            ))}
          </ul>
        ) : null}

        {skills.length > 0 ? (
          <ul class="pill-list" aria-label="Skills">
            {skills.map((skill) => (
              <li class="pill">{skill.resolved ? <a href={skill.href}>{skill.label}</a> : skill.label}</li>
            ))}
          </ul>
        ) : null}

        {hasMoreDetail(item) ? (
          <details class="more-detail">
            <summary>More detail</summary>

            {item.responsibilities?.length ? (
              <>
                <h4 class="role-subheading">Responsibilities</h4>
                <ul class="role-list">{item.responsibilities.map((r) => <li>{r}</li>)}</ul>
              </>
            ) : null}

            {item.achievements?.length ? (
              <>
                <h4 class="role-subheading">Achievements</h4>
                <ul class="role-list">{item.achievements.map((a) => <li>{a}</li>)}</ul>
              </>
            ) : null}

            {item.talks?.length ? (
              <>
                <h4 class="role-subheading">Talks</h4>
                <ul class="role-list">{item.talks.map((t) => <li>{t}</li>)}</ul>
              </>
            ) : null}

            {item.articles?.length ? (
              <>
                <h4 class="role-subheading">Articles</h4>
                <ul class="role-list">{item.articles.map((a) => <li>{a}</li>)}</ul>
              </>
            ) : null}

            {item.certifications?.length ? (
              <>
                <h4 class="role-subheading">Certifications</h4>
                <ul class="role-list">{item.certifications.map((c) => <li>{c}</li>)}</ul>
              </>
            ) : null}
          </details>
        ) : null}
      </article>
    );
  })}
</section>
