---
import type { VolunteeringItem } from "@/lib/schemas/volunteering.schema";

interface Props {
  volunteering: VolunteeringItem[];
  allProjects?: any[];
  allAwards?: any[];
  allCertifications?: any[];
}

const { 
  volunteering = [], 
  allProjects = [], 
  allAwards = [], 
  allCertifications = [] 
} = Astro.props;

const entries = Array.isArray(volunteering) ? volunteering : [];

// Create maps for quick lookup of full objects
const projectMap = new Map(allProjects.map((p: any) => [p.slug, p]));
const awardMap = new Map(allAwards.map((a: any) => [a.id, a]));
const certMap = new Map(allCertifications.map((c: any) => [c.id, c]));

const hasMoreDetail = (item: VolunteeringItem) =>
  Boolean(
    item.projects?.length ||
      item.articles?.length ||
      item.talks?.length ||
      item.relatedAwards?.length ||
      item.relatedCertifications?.length
  );
---

<section id="volunteering" aria-labelledby="volunteering-heading">
  <p class="eyebrow">Community</p>
  <h2 id="volunteering-heading">Volunteering</h2>

  <div class="timeline">
    {entries.map((item) => {
      const location = [item.city, item.country].filter(Boolean).join(", ");
      const hasDates = Boolean(item.startDate || item.endDate);

      return (
        <article class="role-item">
          <div class="role-header">
            <div>
              {item.role ? <span class="role-title">{item.role}</span> : null}
              {item.organisation ? (
                <>
                  {" · "}
                  <span class="role-org">{item.organisation}</span>
                </>
              ) : null}
              {location ? (
                <>
                  {" · "}
                  <span class="role-location">{location}</span>
                </>
              ) : null}
            </div>

            {hasDates ? (
              <time class="role-dates">
                {item.startDate}
                {item.startDate && item.endDate ? " — " : ""}
                {item.current ? "Present" : item.endDate}
              </time>
            ) : null}
          </div>

          {item.summary ? <p>{item.summary}</p> : null}

          {hasMoreDetail(item) ? (
            <details class="more-detail">
              <summary>More detail</summary>
              
              {/* Projects */}
              {item.projects?.length ? (
                <>
                  <h4 class="role-subheading">Projects</h4>
                  <ul class="role-list">
                    {item.projects.map((slug) => {
                      const p = projectMap.get(slug);
                      return (
                        <li>
                          <a href={`https://rjmlaird.co.uk/projects/${slug}`} target="_blank" rel="noopener noreferrer">
                            {p?.title ?? slug}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </>
              ) : null}

              {/* Awards */}
              {item.relatedAwards?.length ? (
                <>
                  <h4 class="role-subheading">Related awards</h4>
                  <ul class="role-list">
                    {item.relatedAwards.map((id) => {
                      const a = awardMap.get(id);
                      return <li>{a?.name ?? id}</li>;
                    })}
                  </ul>
                </>
              ) : null}

              {/* Certifications */}
              {item.relatedCertifications?.length ? (
                <>
                  <h4 class="role-subheading">Related certifications</h4>
                  <ul class="role-list">
                    {item.relatedCertifications.map((id) => {
                      const c = certMap.get(id);
                      return <li>{c?.name ?? id}</li>;
                    })}
                  </ul>
                </>
              ) : null}
              
              {/* Articles & Talks remain as is if they are just strings */}
              {item.articles?.length ? (
                <>
                  <h4 class="role-subheading">Articles</h4>
                  <ul class="role-list">{item.articles.map((a) => <li>{a}</li>)}</ul>
                </>
              ) : null}

              {item.talks?.length ? (
                <>
                  <h4 class="role-subheading">Talks</h4>
                  <ul class="role-list">{item.talks.map((t) => <li>{t}</li>)}</ul>
                </>
              ) : null}
            </details>
          ) : null}
        </article>
      );
    })}
  </div>
</section>