---
import { getExperience } from "@/lib/api";
import { resolveSkillTags } from "@/lib/skills";
import type { ExperienceItem } from "@/lib/schemas/experience.schema";

const experience = (await getExperience()) ?? [];

const formatDate = (value?: string | null) => {
  if (!value) return "";
  const [year, month] = value.split("-");
  if (!year) return value;
  if (!month) return year;
  return new Intl.DateTimeFormat("en-GB", {
    month: "short",
    year: "numeric",
  }).format(new Date(Number(year), Number(month) - 1, 1));
};

const rows = await Promise.all(
  experience.map(async (role: ExperienceItem) => ({
    role,
    skills: await resolveSkillTags(role.skills),
  })),
);

const hasMoreDetail = (role: ExperienceItem) =>
  Boolean(
    role.responsibilities?.length ||
      role.achievements?.length ||
      role.technologies?.length ||
      role.clients?.length ||
      role.articles?.length ||
      role.talks?.length ||
      role.certifications?.length ||
      role.relatedAwards?.length ||
      role.relatedCertifications?.length ||
      role.relatedEducation?.length ||
      role.relatedMemberships?.length ||
      role.relatedOrg?.length,
  );
---

<section id="experience" aria-labelledby="experience-heading">
  <p class="eyebrow">Career history</p>
  <h2 id="experience-heading">Experience</h2>

  {rows.length > 0 ? (
    rows.map(({ role, skills }) => {
      const organisation =
        (typeof role.organisation === "string" ? role.organisation : role.organisation?.name) ??
        "Self-employed";

      const location =
        typeof role.location === "string"
          ? role.location
          : role.location?.city && role.location?.country
            ? `${role.location.city}, ${role.location.country}`
            : role.location?.city ?? role.location?.country ?? "";

      const responsibilities = Array.isArray(role.responsibilities) ? role.responsibilities : [];
      const achievements = Array.isArray(role.achievements) ? role.achievements : [];

      return (
        <article
          id={`exp-${role.id}`}
          class={["role-item", role.current ? "" : "dim"].filter(Boolean).join(" ")}
        >
          <div class="role-header">
            <div>
              <span class="role-title">{role.role}</span>
              {" · "}
              <span class="role-org">{organisation}</span>
              {location ? (
                <>
                  {" · "}
                  <span class="role-location">{location}</span>
                </>
              ) : null}
            </div>

            <time class="role-dates">
              {role.startDate}
              {" — "}
              {role.current ? "Present" : role.endDate}
            </time>
          </div>

          <p>{role.summary ?? ""}</p>

          {responsibilities.length > 0 ? (
            <ul class="role-list">
              {responsibilities.map((item) => <li>{item}</li>)}
            </ul>
          ) : null}

          {achievements.length > 0 ? (
            <>
              <h3 class="role-subheading">Achievements</h3>
              <ul class="role-list">
                {achievements.map((item) => <li>{item}</li>)}
              </ul>
            </>
          ) : null}

          {skills.length > 0 ? (
            <ul class="pill-list" aria-label="Skills used in this role">
              {skills.map((skill) => (
                <li class="pill">
                  {skill.resolved ? <a href={skill.href}>{skill.label}</a> : skill.label}
                </li>
              ))}
            </ul>
          ) : null}

          {hasMoreDetail(role) ? (
            <details class="more-detail">
              <summary>More detail</summary>

              {role.technologies?.length ? (
                <>
                  <h4 class="role-subheading">Technologies</h4>
                  <ul class="pill-list">
                    {role.technologies.map((t) => <li class="pill pill--mono">{t}</li>)}
                  </ul>
                </>
              ) : null}

              {role.clients?.length ? (
                <>
                  <h4 class="role-subheading">Clients</h4>
                  <ul class="role-list">{role.clients.map((c) => <li>{c}</li>)}</ul>
                </>
              ) : null}

              {role.talks?.length ? (
                <>
                  <h4 class="role-subheading">Talks</h4>
                  <ul class="role-list">{role.talks.map((t) => <li>{t}</li>)}</ul>
                </>
              ) : null}

              {role.articles?.length ? (
                <>
                  <h4 class="role-subheading">Articles</h4>
                  <ul class="role-list">{role.articles.map((a) => <li>{a}</li>)}</ul>
                </>
              ) : null}

              {role.certifications?.length ? (
                <>
                  <h4 class="role-subheading">Certifications</h4>
                  <ul class="role-list">
                    {role.certifications.map((c) => <li>{c}</li>)}
                  </ul>
                </>
              ) : null}

              {role.relatedAwards?.length ? (
                <>
                  <h4 class="role-subheading">Related awards</h4>
                  <ul class="role-list">
                    {role.relatedAwards.map((award) => <li>{award}</li>)}
                  </ul>
                </>
              ) : null}

              {role.relatedCertifications?.length ? (
                <>
                  <h4 class="role-subheading">Related certifications</h4>
                  <ul class="role-list">
                    {role.relatedCertifications.map((cert) => <li>{cert}</li>)}
                  </ul>
                </>
              ) : null}

              {role.relatedEducation?.length ? (
                <>
                  <h4 class="role-subheading">Related education</h4>
                  <ul class="role-list">
                    {role.relatedEducation.map((edu) => <li>{edu}</li>)}
                  </ul>
                </>
              ) : null}

              {role.relatedMemberships?.length ? (
                <>
                  <h4 class="role-subheading">Related memberships</h4>
                  <ul class="role-list">
                    {role.relatedMemberships.map((membership) => <li>{membership}</li>)}
                  </ul>
                </>
              ) : null}

              {role.relatedOrg?.length ? (
                <>
                  <h4 class="role-subheading">Related organisations</h4>
                  <ul class="role-list">
                    {role.relatedOrg.map((org) => <li>{org}</li>)}
                  </ul>
                </>
              ) : null}
            </details>
          ) : null}
        </article>
      );
    })
  ) : null}
</section>
