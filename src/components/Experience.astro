---
import { getExperience } from '@/lib/api';

type ExperienceItem = {
  title: string;
  org: string;
  dates: string;
  description?: string;
  dim?: boolean;
};

const rawExperience = await getExperience<ExperienceItem[]>();
const experience = Array.isArray(rawExperience) ? rawExperience : [];
---

<section id="experience" aria-labelledby="experience-heading">
  <p class="eyebrow">Career history</p>
  <h2 id="experience-heading">Experience</h2>

  {experience.map((role) => (
    <article class={['role-item', role.dim ? 'dim' : ''].filter(Boolean).join(' ')}>
      <div class="role-header">
        <div>
          <span class="role-title">{role.title}</span>
          {' · '}
          <span class="role-org">{role.org}</span>
        </div>
        <time class="role-dates">{role.dates}</time>
      </div>

      {role.description && <p>{role.description}</p>}
    </article>
  ))}
</section>
