---
import { getProfile } from "@/lib/api";

let profile = null;

try {
  profile = await getProfile();
} catch {
  profile = null;
}

const name = profile?.name ?? "Ryan Laird";
const credentials = profile?.credentials ?? "";
const summary = Array.isArray(profile?.summary) ? profile.summary : [];
const portfolioLinks = Array.isArray(profile?.portfolioLinks) ? profile.portfolioLinks : [];
const tags = Array.isArray(profile?.tags) ? profile.tags : [];
const contact = Array.isArray(profile?.contact) ? profile.contact : [];

const roleHtml =
  typeof profile?.role === "string"
    ? profile.role.replace("Green Orbit Digital", "<strong>Green Orbit Digital</strong>")
    : "";
---

<section class="hero" aria-labelledby="hero-heading">
  <svg class="orbit-decor" viewBox="0 0 150 150" aria-hidden="true" focusable="false">
    <circle cx="75" cy="75" r="70" fill="none" stroke="#2dd4bf" stroke-opacity="0.25" stroke-width="1" />
    <circle cx="75" cy="75" r="48" fill="none" stroke="#f2b544" stroke-opacity="0.2" stroke-width="1" stroke-dasharray="3 5" />
    <circle cx="75" cy="5" r="3.5" fill="#2dd4bf" />
    <circle cx="123" cy="75" r="2.5" fill="#f2b544" />
  </svg>

  <p class="eyebrow">Curriculum Vitae</p>
  <h1 id="hero-heading">{name}</h1>

  {roleHtml && <p class="role" set:html={roleHtml} />}
  {credentials && <p class="credentials">{credentials}</p>}

  {summary.length > 0 && (
    <div class="hero-summary">
      {summary.map((paragraph) => <p>{paragraph}</p>)}

    </div>
  )}

  {tags.length > 0 && (
    <div class="tag-row" aria-label="Core competencies">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}

</section>
