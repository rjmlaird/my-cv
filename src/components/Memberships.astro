---
import { getMemberships } from "@/lib/api";
import type { MembershipGroup } from "@/lib/schemas/membership.schema";

const memberships = (await getMemberships()) ?? [];

const TYPE_LABELS: Record<string, string> = {
  chartered_body: "Chartered Body",
  professional_body: "Professional Body",
  scientific_body: "Scientific Body",
  security_body: "Security Body",
  industry_association: "Industry Association",
  climate_network: "Climate Network",
  research_network: "Research Network",
  media_network: "Media Network",
  creative_network: "Creative Network",
  space_network: "Space Network",
  urban_network: "Urban Network",
  sustainability_network: "Sustainability Network",
  business_association: "Business Association",
  startup_network: "Startup Network",
  community_network: "Community Network",
  ethics_framework: "Ethics Framework",
  education_network: "Education Network",
  framework_network: "Framework Network",
  economic_network: "Economic Network",
  advocacy_network: "Advocacy Network",
  climate_lab: "Climate Lab",
  industry_initiative: "Industry Initiative",
  nonprofit_network: "Nonprofit Network",
  ethics_network: "Ethics Network",
  business_climate_network: "Business Climate Network",
  urban_innovation_network: "Urban Innovation Network",
  astronomy_network: "Astronomy Network",
  environmental_ngo: "Environmental NGO",
};
---

<section id="memberships" aria-labelledby="memberships-heading">
  <p class="eyebrow">Professional standing</p>
  <h2 id="memberships-heading">Professional Memberships &amp; Affiliations</h2>

  <div class="membership-groups">
    {memberships.map((group: MembershipGroup) => (
      <article class="membership-group">
        <h3 class="membership-group-title">{group.title}</h3>

        <div class="membership-columns">
          {group.items.map((item) => (
            <div class="membership-entry">
              <div class="role-header">
                <div>
                  <span class="role-title">{item.role}</span>
                  {item.organisation ? (
                    <>
                      {" · "}
                      <span class="role-org">{item.organisation}</span>
                    </>
                  ) : null}
                </div>

                <span class="pill">{TYPE_LABELS[item.type] ?? item.type}</span>
              </div>
            </div>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .membership-groups {
    display: grid;
    gap: 2rem;
  }

  .membership-group {
    display: grid;
    gap: 1rem;
  }

  .membership-group-title {
    margin: 0;
  }

  .membership-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem 2rem;
  }

  .membership-entry {
    min-width: 0;
  }

  @media (max-width: 48rem) {
    .membership-columns {
      grid-template-columns: 1fr;
    }
  }
  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    font-size: 0.875rem;
    line-height: 1;
    white-space: nowrap;
  }
</style>
