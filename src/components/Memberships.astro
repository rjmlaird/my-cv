---
import { getMemberships } from "@/lib/api";

let membershipGroups: Awaited<ReturnType<typeof getMemberships>> = [];

try {
  membershipGroups = await getMemberships();
} catch {
  membershipGroups = [];
}
---

{membershipGroups.length > 0 && (
  <section id="memberships" aria-labelledby="memberships-heading">
    <p class="eyebrow">Professional standing</p>
    <h2 id="memberships-heading">Memberships</h2>

    <div class="membership-groups">
      {membershipGroups.map((group) => (
        <div class="membership-group">
          <h3 class="membership-group-title">{group.title}</h3>

          <div class="membership-list">
            {group.items.map((item) => (
              <article class="membership-entry" id={`membership-${item.organisationSlug || item.organisation}`}>
                <div class="membership-entry-header">
                  <span class="membership-org">{item.organisation}</span>
                  {item.role && <span class="membership-role">{item.role}</span>}
                  {item.type && <span class="membership-type">{item.type}</span>}
                </div>

                {item.description && (
                  <details class="more-detail">
                    <summary>More detail</summary>
                    <p>{item.description}</p>
                  </details>
                )}
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
)}
