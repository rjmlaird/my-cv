---
import { navLinks } from "@/data/nav";
---

<a class="skip-link" href="#main-content">Skip to main content</a>

<header class="site-header">
  <div class="site-header-inner">
    <div class="header-top">
      <a class="nav-name" href="/" aria-label="Ryan Laird home">
        Ryan <span>Laird</span>
      </a>

      <nav class="nav-links" aria-label="Section navigation">
        <ul>
          {navLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="nav-actions">
  <button class="btn" id="ats-toggle" type="button" aria-pressed="false">
    ATS view
  </button>
  <button class="btn secondary" id="print-btn" type="button">
    Download / Print
  </button>
</div>
  </div>
</header>

<script>
  const atsToggle = document.getElementById("ats-toggle");
  const printBtn = document.getElementById("print-btn");

  if (atsToggle instanceof HTMLButtonElement) {
    atsToggle.addEventListener("click", () => {
      const isAts = document.body.classList.toggle("ats-mode");
      atsToggle.setAttribute("aria-pressed", String(isAts));
      atsToggle.textContent = isAts ? "Visual view" : "ATS view";
      if (isAts) window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  if (printBtn instanceof HTMLButtonElement) {
    printBtn.addEventListener("click", () => window.print());
  }
</script>

<style>
  .skip-link {
    position: absolute;
    left: 0.75rem;
    top: -3rem;
    z-index: 1000;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: #fff;
    color: #000;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  .skip-link:focus {
    top: 0.75rem;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent);
  }

  .site-header-inner {
    display: grid;
    gap: 0.75rem;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.9rem 1rem;
  }

  .header-top {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .nav-name {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex: 0 0 auto;
  }

  .nav-name span {
    opacity: 0.75;
  }

  .nav-links {
    flex: 1 1 24rem;
    min-width: 0;
  }

  .nav-links ul {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    gap: 0.35rem 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.65rem 0.8rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    line-height: 1;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible,
  .nav-actions .btn:hover,
  .nav-actions .btn:focus-visible {
    outline: none;
    background: color-mix(in srgb, currentColor 8%, transparent);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 16%, transparent);
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: pointer;
    white-space: nowrap;
  }

  .btn.primary {
    background: currentColor;
    color: var(--bg);
  }
.nav-actions {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-left: auto;
}

.btn.secondary {
  background: orange;
  color: #white;
  border-color: orange;
}

.btn.secondary:hover,
.btn.secondary:focus-visible {
  background: background: transparent;
  border-color: color-mix(in srgb, orange 88%, black);
}

</style>
