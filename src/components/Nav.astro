---
import { navLinks } from "@/data/nav";
---

<header class="site-header" id="site-header">
  <div class="site-header-inner">
    <div class="header-top">
      <a class="nav-name" href="/" aria-label="Ryan Laird home">
        Ryan <span>Laird</span>
      </a>

      <button id="menu-toggle" aria-expanded="false" aria-controls="nav-list" aria-label="Toggle menu">
        <span class="hamburger"></span>
      </button>

      <nav class="nav-links" id="nav-list" aria-label="Section navigation">
        <ul>
          {navLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="nav-actions">
      <button class="btn" id="ats-toggle" type="button" aria-pressed="false">
        ATS view
      </button>
      <button class="btn secondary" id="print-btn" type="button">
        Download / Print
      </button>
    </div>
  </div>
</header>

<script>
  // Scroll-hide logic
  let lastScroll = 0;
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    if (currentScroll > lastScroll && currentScroll > 100) {
      header?.classList.add('nav-hidden');
    } else {
      header?.classList.remove('nav-hidden');
    }
    lastScroll = currentScroll;
  });

  // Mobile menu toggle
  const menuToggle = document.getElementById('menu-toggle');
  const navList = document.getElementById('nav-list');
  menuToggle?.addEventListener('click', () => {
    const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!expanded));
    navList?.classList.toggle('open');
  });

  // ATS & Print logic
  const atsToggle = document.getElementById("ats-toggle");
  const printBtn = document.getElementById("print-btn");

  atsToggle?.addEventListener("click", () => {
    const isAts = document.body.classList.toggle("ats-mode");
    atsToggle.setAttribute("aria-pressed", String(isAts));
    atsToggle.textContent = isAts ? "Visual view" : "ATS view";
    if (isAts) window.scrollTo({ top: 0, behavior: "smooth" });
  });

  printBtn?.addEventListener("click", () => window.print());
</script>

<style>
  .skip-link {
    position: absolute;
    left: 0.75rem;
    top: -3rem;
    z-index: 1000;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: #fff;
    color: #000;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  .skip-link:focus { top: 0.75rem; }

  .site-header {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 50;
    transition: transform 0.3s ease;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent);
  }

  .nav-hidden { transform: translateY(-100%); }

  .site-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.5rem 1.5rem;
  }

  .header-top {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    min-width: 0;
  }

  .nav-name {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-name span { opacity: 0.75; }

  /* Hamburger Styles */
  #menu-toggle { display: none; background: none; border: none; padding: 0.5rem; cursor: pointer; flex-shrink: 0; }
  .hamburger { display: block; width: 24px; height: 2px; background: currentColor; position: relative; }
  .hamburger::before, .hamburger::after { content: ''; position: absolute; width: 24px; height: 2px; background: currentColor; left: 0; }
  .hamburger::before { top: -8px; }
  .hamburger::after { top: 8px; }

  .nav-links ul { display: flex; list-style: none; gap: 0.5rem; margin: 0; padding: 0; }
  .nav-links a { display: inline-flex; align-items: center; min-height: 44px; padding: 0.65rem 0.8rem; border-radius: 999px; text-decoration: none; font-weight: 500; }

  .nav-actions { display: flex; align-items: center; gap: 0.75rem; margin-left: 1.5rem; flex-shrink: 0; }

  .btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 16%, transparent);
    background: transparent;
    cursor: pointer;
  }

  .btn.secondary { background: orange; color: #fff; border-color: orange; }

  @media (max-width: 900px) {
    #menu-toggle { display: block; }
    .nav-links { display: none; position: absolute; top: 100%; left: 0; width: 100%; background: var(--bg); padding: 1rem; border-bottom: 1px solid #ccc; }
    .nav-links.open { display: block; }
    .nav-links ul { flex-direction: column; }
    .nav-actions { margin-left: auto; }
  }
</style>