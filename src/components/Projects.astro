---
import { getProjects } from "@/lib/api";
import { resolveSkillTags } from "@/lib/skills";

let projects: Awaited<ReturnType<typeof getProjects>> = [];

try {
  projects = await getProjects();
} catch {
  projects = [];
}

const orderedProjects = [...projects].sort((a, b) => {
  const rank = { featured: 0, collaborative: 1, community: 2, other: 3, automation: 3 } as const;
  const ra = rank[a.type as keyof typeof rank] ?? 3;
  const rb = rank[b.type as keyof typeof rank] ?? 3;
  if (ra !== rb) return ra - rb;
  return (b.date ?? "").localeCompare(a.date ?? "");
});

const linkLabels: Record<string, string> = {
  github: "Code",
  live: "Live site",
  demo: "Demo",
  docs: "Docs",
  video: "Video",
  store: "Store",
  api: "API",
};

const projectsWithSkills = await Promise.all(
  orderedProjects.map(async (project) => ({
    project,
    resolvedSkills: await resolveSkillTags(project.skills),
  })),
);

const clientsOf = (project: (typeof orderedProjects)[number]) =>
  project.client ? (Array.isArray(project.client) ? project.client : [project.client]) : [];

const experienceOf = (project: (typeof orderedProjects)[number]) =>
  project.experience ? (Array.isArray(project.experience) ? project.experience : [project.experience]) : [];

const hasExtraDetail = (project: (typeof orderedProjects)[number]) =>
  Boolean(
    (project.caseStudies && project.caseStudies.length) ||
      (project.articles && project.articles.length) ||
      (project.awards && project.awards.length) ||
      (project.impact && Object.keys(project.impact).length) ||
      (project.features && project.features.length),
  );
---

{orderedProjects.length > 0 && (
  <section id="projects" aria-labelledby="projects-heading">
    <p class="eyebrow">Selected work</p>
    <h2 id="projects-heading">Projects</h2>

    <div class="projects-grid">
      {projectsWithSkills.map(({ project, resolvedSkills }) => (
        <article class="project-card" id={`project-${project.slug}`}>
          <div class="project-card-top">
            <h3>{project.title}</h3>
            {project.type && <span class={`project-type project-type--${project.type}`}>{project.type.replace("_", " ")}</span>}
          </div>

          {project.description && <p>{project.description}</p>}

          {(clientsOf(project).length > 0 || experienceOf(project).length > 0) && (
            <p class="project-context">
              {clientsOf(project).map((c) => c.name).join(", ")}
              {clientsOf(project).length > 0 && experienceOf(project).length > 0 ? " · " : ""}
              {experienceOf(project)
                .map((e) => [e.role, e.organisation].filter(Boolean).join(", "))
                .join("; ")}
            </p>
          )}

          {Array.isArray(project.toolsTech) && project.toolsTech.length > 0 && (
            <ul class="pill-list" aria-label="Tools and technologies">
              {project.toolsTech.map((tool) => (
                <li class="pill pill--mono">{tool}</li>
              ))}
            </ul>
          )}

          {resolvedSkills.length > 0 && (
            <ul class="pill-list" aria-label="Skills applied">
              {resolvedSkills.map((skill) => (
                <li class="pill">
                  {skill.resolved ? <a href={skill.href}>{skill.label}</a> : skill.label}
                </li>
              ))}
            </ul>
          )}

          {project.links && Object.keys(project.links).length > 0 && (
            <div class="project-links">
              {Object.entries(project.links).map(([key, href]) =>
                href ? (
                  <a href={href} target="_blank" rel="noopener noreferrer">
                    {linkLabels[key] ?? key}
                  </a>
                ) : null,
              )}
            </div>
          )}

          {hasExtraDetail(project) && (
            <details class="project-more">
              <summary>More detail</summary>

              {Array.isArray(project.features) && project.features.length > 0 && (
                <>
                  <h4>Features</h4>
                  <ul class="role-list">
                    {project.features.map((feature) => <li>{feature}</li>)}
                  </ul>
                </>
              )}

              {project.impact && Object.keys(project.impact).length > 0 && (
                <>
                  <h4>Impact</h4>
                  <ul class="role-list">
                    {Object.entries(project.impact).map(([key, value]) => (
                      <li>
                        <strong>{key}:</strong> {String(value)}
                      </li>
                    ))}
                  </ul>
                </>
              )}

              {Array.isArray(project.caseStudies) && project.caseStudies.length > 0 && (
                <>
                  <h4>Case studies</h4>
                  <ul class="role-list">
                    {project.caseStudies.map((cs) => (
                      <li>{cs.url ? <a href={cs.url} target="_blank" rel="noopener noreferrer">{cs.title}</a> : cs.title}</li>
                    ))}
                  </ul>
                </>
              )}

              {Array.isArray(project.articles) && project.articles.length > 0 && (
                <>
                  <h4>Articles</h4>
                  <ul class="role-list">
                    {project.articles.map((a) => (
                      <li>
                        <a href={a.url} target="_blank" rel="noopener noreferrer">{a.title}</a>
                        {a.publisher ? ` — ${a.publisher}` : ""}
                      </li>
                    ))}
                  </ul>
                </>
              )}

              {Array.isArray(project.awards) && project.awards.length > 0 && (
                <>
                  <h4>Awards</h4>
                  <ul class="role-list">
                    {project.awards.map((award) => (
                      <li>
                        {award.title}
                        {award.organisation ? ` — ${award.organisation}` : ""}
                        {award.year ? ` (${award.year})` : ""}
                      </li>
                    ))}
                  </ul>
                </>
              )}
            </details>
          )}
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: grid;
    gap: 0.6rem;
    align-content: start;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--bg-panel);
  }

  .project-card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .project-card-top h3 {
    margin: 0;
  }

  .project-type {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--amber);
    border: 1px solid var(--border-strong);
    border-radius: 9999px;
    padding: 0.2rem 0.6rem;
  }

  .project-context {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .project-more h4 {
    margin: 0.75rem 0 0.35rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--muted);
  }
</style>
