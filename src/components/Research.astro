---
// Import the entire API object as a namespace
import api from "@/lib/api";

interface Props {
  item?: Record<string, any>;
  index?: number;
  bibText?: string;
}

const props = Astro.props as Props;
const item = props.item ?? {};
const bibText = props.bibText ?? "";
const number = props.index ? String(props.index).padStart(2, "0") : "";

// Corrected: Call the function from the api object
const allSocials = await api.getSocials();
const academicProfiles = allSocials.filter((s: any) => s.type === "academic");

// Helper functions: Prefixed unused parameters with _ to satisfy ts(6133)
const normalizeTitle = (i: any) => (Array.isArray(i.title) ? i.title.join(" ") : i.title || "Untitled");
const normalizeAuthors = (_a: unknown) => ""; 
const normalizeYear = (i: any) => i?.issued?.["date-parts"]?.[0]?.[0] || i?.year || "";
const normalizeContainer = (i: any) => i["container-title"] || i.journal || i.booktitle || i.publisher || "";

const title = normalizeTitle(item);
const authors = normalizeAuthors(item.author);
const year = normalizeYear(item);
const publication = normalizeContainer(item);
const url = item.URL || item.url || "";
const doi = item.DOI || item.doi || "";
const recordUrl = url || (doi ? `https://doi.org/${doi}` : "");
const pdf = ""; 
const keywords = Array.isArray(item.keywords) ? item.keywords : [];
const titleUrl = doi ? `https://doi.org/${doi}` : url;
const bibtexHref = `data:text/x-bibtex;charset=utf-8,${encodeURIComponent(bibText)}`;
---

<section id="research" aria-labelledby="research-heading">
  <p class="eyebrow">Publications</p>
  <h2 id="research-heading">Research</h2>
  
  <p class="intro-text">
    I am actively engaged in ongoing research. You can explore my full portfolio of peer-reviewed work and citations on my 
    {academicProfiles.map((p: any, i: number) => (
      <Fragment>
        <a href={p.url} target="_blank" rel="noopener noreferrer">{p.name}</a>{i < academicProfiles.length - 1 ? ", " : "."}
      </Fragment>
    ))}
  </p>

  <article class="pr pub">
    <p class="pn">{number}</p>
    <div class="pm">
      <div class="pub-top">
        <h3>{titleUrl ? <a href={titleUrl} target="_blank" rel="noopener noreferrer">{title}</a> : title}</h3>
        {year && <span class="date">{year}</span>}
      </div>
      {publication && <div class="client-badge">{publication}</div>}
      {authors && <p class="authors">{authors}</p>}
      
      {keywords.length > 0 && (
        <div class="pt">
          {keywords.map((t: string) => <span class="tag">{t}</span>)}
        </div>
      )}

      <div class="action-row">
        <a class="pa" href={bibtexHref} download="publications.bib">BibTeX</a>
        {doi && <a class="pa" href={`https://doi.org/${doi}`} target="_blank">DOI</a>}
        {pdf && <a class="pa" href={pdf} target="_blank">Download</a>}
        {recordUrl && <a class="pa pa-primary" href={recordUrl} target="_blank">View</a>}
      </div>
    </div>
  </article>
</section>