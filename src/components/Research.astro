---
import { research } from '@/data/awards';
---

<section id="research" aria-labelledby="research-heading">
  <p class="eyebrow">Academic contributions</p>
  <h2 id="research-heading">Research</h2>
  {research.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
  <p class="research-orcid">
    ORCID: <a href={research.orcid} target="_blank" rel="noopener">{research.orcid.replace('https://orcid.org/', '')}</a>
  </p>
</section>