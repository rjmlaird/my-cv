---
import api from "@/lib/api";
import { Icon } from "astro-icon/components";

interface SocialProfile {
  name: string;
  url: string;
  type: string;
  icon: string;
  label: string;
}

// Fetch socials and filter by "academic"
const allSocials = (await api.getSocials()) ?? [];
const academicProfiles: SocialProfile[] = allSocials.filter(
  (s: SocialProfile) => s.type === "academic"
);
---

<section id="research" aria-labelledby="research-heading">
  <p class="eyebrow">Publications</p>
  <h2 id="research-heading">Research</h2>
  
  {academicProfiles.length > 0 && (
    <div class="intro-text">
      <p>I am actively engaged in ongoing research. You can explore my full portfolio of peer-reviewed work and citations here:</p>
      <div class="social-icons" style="display: flex; gap: 1rem; margin-top: 1rem;">
        {academicProfiles.map((p: SocialProfile) => (
          <a 
            href={p.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            aria-label={p.label} 
            title={p.name}
          >
            <Icon name={p.icon} size={24} />
          </a>
        ))}
      </div>
    </div>
  )}
</section>