---
import skillsData from "../data/skills.json";

const { mode = "human" } = Astro.props;

// Your JSON is structured as { skills: { ...groups } }
const rawGroups = skillsData?.skills;

// Normalise safely into an array of groups
const skillGroups = rawGroups && typeof rawGroups === "object"
  ? Object.values(rawGroups)
  : [];

// Flatten keywords for ATS mode (fully defensive)
const flatSkills = skillGroups
  .flatMap((group) => {
    if (!group || typeof group !== "object") return [];
    if (!Array.isArray(group.keywords)) return [];
    return group.keywords;
  })
  .filter((skill) => typeof skill === "string" && skill.trim().length > 0)
  .map((s) => s.trim())
  .sort((a, b) => a.localeCompare(b));

const isATS = mode === "ats";
---

<section class="skills">

  {isATS ? (
    <div class="ats-mode">
      <p class="text-xs text-gray-500 mb-3">
        Flattened keyword dataset for parsing and indexing systems
      </p>

      {flatSkills.length > 0 ? (
        <div class="flex flex-wrap gap-2">
          {flatSkills.map((skill) => (
            <span class="ats-skill" data-skill={skill}>
              {skill}
            </span>
          ))}
        </div>
      ) : (
        <p class="text-sm text-gray-400">No skills available</p>
      )}
    </div>
  ) : (
    <div class="human-mode grid gap-6 md:grid-cols-2">
      {skillGroups.length > 0 ? (
        skillGroups.map((group) => (
          <div class="skill-group break-inside-avoid">
            <h3 class="font-semibold text-lg mb-2">
              {group.label ?? "Uncategorised Skills"}
            </h3>

            {Array.isArray(group.keywords) && group.keywords.length > 0 ? (
              <ul class="flex flex-wrap gap-2">
                {group.keywords.map((skill) => (
                  <li class="skill-pill">
                    {skill}
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-sm text-gray-400">
                No skills listed
              </p>
            )}
          </div>
        ))
      ) : (
        <p class="text-sm text-gray-500">
          No skills available
        </p>
      )}
    </div>
  )}
</section>

<style>
  .skill-pill {
    @apply px-3 py-1 rounded-full bg-gray-100 text-sm text-gray-700;
  }

  .ats-skill {
    @apply text-xs px-2 py-1 border border-gray-300 rounded;
  }

  .skill-group {
    @apply break-inside-avoid;
  }
</style>