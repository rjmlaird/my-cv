---
import { getExperience, getEducation } from "@/lib/api";
import { aggregateSkills, groupSkillsByCategory, type SkillSource } from "@/lib/skills";

const visibleCount = 6;

let experience: Awaited<ReturnType<typeof getExperience>> = [];
let education: Awaited<ReturnType<typeof getEducation>> = [];

try {
  [experience, education] = await Promise.all([getExperience(), getEducation()]);
} catch {
  experience = [];
  education = [];
}

const orgName = (role: (typeof experience)[number]) =>
  (typeof role.organisation === "string" ? role.organisation : role.organisation?.name) ?? "";

const makeRefLabel = (...parts: Array<string | undefined | null>) =>
  parts.filter(Boolean).join(" · ");

const sources: SkillSource[] = [
  ...experience.map((role) => ({
    tags: role.skills,
    ref: {
      label: makeRefLabel(role.role, orgName(role)),
      href: `#exp-${role.id}`,
    },
  })),
  ...education.map((item) => ({
    tags: item.skills,
    ref: {
      label: makeRefLabel(item.qualification || item.role, item.institution),
      href: `#edu-${item.id}`,
    },
  })),
];

const aggregated = await aggregateSkills(sources);
const grouped = groupSkillsByCategory(aggregated);
---

{aggregated.length > 0 && (
  <section id="skills" aria-labelledby="skills-heading">
    <p class="eyebrow">Capabilities, as applied</p>
    <h2 id="skills-heading">Skills</h2>

    <p class="section-intro">
      Intro
    </p>

    <div class="skills-grid">
      {grouped.map(({ category, skills }) => {
        const visibleSkills = skills.slice(0, visibleCount);
        const hiddenSkills = skills.slice(visibleCount);

        return (
          <article class="skill-group">
            <h3>{category}</h3>

            <ul class="skill-tags" aria-label={`${category} skills`}>
              {visibleSkills.map((skill) => (
                <li
                  id={`skill-${skill.slug}`}
                  class={`skill-tag ${skill.resolved ? "skill-tag--resolved" : "skill-tag--unresolved"}`}
                >
                  <details class="skill-detail">
                    <summary>
                      {skill.label}
                      {skill.count > 1 && <span class="skill-count">×{skill.count}</span>}
                    </summary>

                    {skill.description && <p>{skill.description}</p>}
                    {skill.proficiency && <p class="skill-proficiency">{skill.proficiency}</p>}

                    <details class="more-detail skill-detail--nested">
                      <summary>More detail</summary>

                      <ul class="skill-usage">
                        {skill.usedIn.map((ref) => (
                          <li><a href={ref.href}>{ref.label}</a></li>
                        ))}
                      </ul>
                    </details>
                  </details>
                </li>
              ))}
            </ul>

            {hiddenSkills.length > 0 ? (
              <details class="more-detail skill-group__more">
                <summary>More detail</summary>

                <ul class="skill-tags" aria-label={`${category} additional skills`}>
                  {hiddenSkills.map((skill) => (
                    <li
                      id={`skill-${skill.slug}`}
                      class={`skill-tag ${skill.resolved ? "skill-tag--resolved" : "skill-tag--unresolved"}`}
                    >
                      <details class="skill-detail">
                        <summary>
                          {skill.label}
                          {skill.count > 1 && <span class="skill-count">×{skill.count}</span>}
                        </summary>

                        {skill.description && <p>{skill.description}</p>}
                        {skill.proficiency && <p class="skill-proficiency">{skill.proficiency}</p>}

                        <details class="more-detail skill-detail--nested">
                          <summary>More detail</summary>

                          <ul class="skill-usage">
                            {skill.usedIn.map((ref) => (
                              <li><a href={ref.href}>{ref.label}</a></li>
                            ))}
                          </ul>
                        </details>
                      </details>
                    </li>
                  ))}
                </ul>
              </details>
            ) : null}
          </article>
        );
      })}
    </div>
  </section>
)}

<style>
  .section-intro {
    max-width: 60ch;
  }

  .skill-detail {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .skill-detail summary {
    font: inherit;
  }

  .more-detail summary {
    display: flex;
    align-items: center;
    gap: 0.4em;
    text-transform: none;
    letter-spacing: normal;
    font-family: var(--font-body);
    font-size: inherit;
    color: inherit;
    cursor: pointer;
  }

  .more-detail summary::before {
    content: "+";
  }

  .more-detail[open] > summary::before {
    content: "−";
  }

  .skill-count {
    color: var(--muted-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .skill-detail p {
    margin: 0.4em 0 0;
    max-width: 32ch;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .skill-proficiency {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.68rem !important;
    color: var(--teal) !important;
  }

  .skill-detail--nested {
    margin-top: 0.5rem;
  }

  .skill-usage {
    margin: 0.5em 0 0;
    padding-left: 1em;
    display: grid;
    gap: 0.25em;
    list-style: disc;
    font-size: 0.78rem;
  }

  .skill-usage a {
    color: var(--muted);
    text-decoration-color: var(--border-strong);
  }

  .skill-usage a:hover {
    color: var(--teal);
  }

  .skill-group__more {
    margin-top: 0.75rem;
  }
</style>
