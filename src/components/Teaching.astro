---
import { getTeaching } from "@/lib/api";

let teaching = null;

try {
  teaching = await getTeaching();
} catch {
  teaching = null;
}

const org = typeof teaching?.org === "string" ? teaching.org : "";
const items = Array.isArray(teaching?.items) ? teaching.items : [];
---

<section id="teaching" aria-labelledby="teaching-heading">
  <p class="eyebrow">Academic instruction</p>
  <h2 id="teaching-heading">Teaching</h2>

  {org && <p class="teaching-org">{org}</p>}

  {items.length > 0 && (
    <ul class="teaching-list">
      {items.map((item) => <li>{item}</li>)}
    </ul>
  )}
</section>
