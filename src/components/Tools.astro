---
import type { ToolData } from "@/lib/schemas/tool.schema";

interface Props {
  data: ToolData;
}

const { data } = Astro.props;
const techStack = data ?? { categories: [] };

// Updated interface to handle the potential null from the API
function badgeUrl(item: { 
  name: string; 
  color: string; 
  logo?: string | null; 
  logoColor?: string | null 
}): string {
  const label = encodeURIComponent(item.name);
  const color = item.color.replace("#", "");
  
  // Normalize logo and logoColor to string or undefined
  const logo = item.logo ? `&logo=${encodeURIComponent(item.logo)}` : "";
  const logoColor = `&logoColor=${item.logoColor ?? "white"}`;
  
  return `https://img.shields.io/badge/-${label}-${color}?style=flat-square${logo}${logoColor}`;
}
---

<section id="tech" aria-labelledby="tech-heading">
  <p class="eyebrow">Tools & Technologies</p>
  
  <h2 id="tech-heading">
    <a href="#tech-stack">Tech stack</a>
  </h2>

  <p class="section-intro">
    A curated collection of the primary tools, languages, and frameworks I utilise for full-stack development and infrastructure design.
  </p>

  <div class="stack-groups">
    {techStack.categories.map((cat) => (
      <article class="stack-group">
        <h3>{cat.name}</h3>
        
        <div class="stack-badges">
          {cat.items.map((item) => (
            <a href={item.url} target="_blank" rel="noopener noreferrer">
              <img 
                src={badgeUrl({
                  name: item.name,
                  color: item.color,
                  logo: item.logo,
                  logoColor: item.logoColor
                })} 
                alt={item.name} 
                title={item.name}
                loading="lazy" 
              />
            </a>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  #tech-stack {
    margin-bottom: 3rem;
  }

  .eyebrow {
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  h2 a {
    text-decoration: none;
    color: inherit;
  }

  h2 a:hover {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 6px;
  }

  h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--text-heading);
  }

  .section-intro {
    max-width: 60ch;
    margin-bottom: 2rem;
    color: var(--muted);
  }

  .stack-groups {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .stack-groups {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .stack-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  img {
    height: 24px;
    transition: transform 0.2s;
  }

  img:hover {
    transform: scale(1.05);
  }
</style>