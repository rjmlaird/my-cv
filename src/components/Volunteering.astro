---
import type { VolunteeringItem } from "@/lib/schemas/volunteering.schema";

interface Props {
  volunteering: VolunteeringItem[];
  allProjects?: any[];
  allAwards?: any[];
  allCertifications?: any[];
}

const { 
  volunteering = [], 
  allProjects = [], 
  allAwards = [], 
  allCertifications = [] 
} = Astro.props;

// Sort by order
const entries = Array.isArray(volunteering) 
  ? [...volunteering].sort((a, b) => (a.order ?? 0) - (b.order ?? 0)) 
  : [];

const projectMap = new Map(allProjects.map((p: any) => [p.slug, p]));
const awardMap = new Map(allAwards.map((a: any) => [a.id, a]));

const hasMoreDetail = (item: VolunteeringItem) =>
  (item.projects?.length ?? 0) > 0 ||
  (item.articles?.length ?? 0) > 0 ||
  (item.talks?.length ?? 0) > 0 ||
  (item.relatedAwards?.length ?? 0) > 0 ||
  (item.relatedCertifications?.length ?? 0) > 0;
---

<section id="volunteering" aria-labelledby="volunteering-heading">
  <p class="eyebrow">Community</p>
  <h2 id="volunteering-heading">Volunteering</h2>

  <div class="timeline">
    {entries.length > 0 ? (
      entries.map((item) => {
        const location = [item.city, item.country].filter(Boolean).join(", ");
        
        return (
          <article class="role-item" id={`${item.id}`}>
            {/* Header always renders */}
            <div class="role-header">
              <div>
                <span class="role-title">{item.role}</span>
                {item.organisation ? <> · <span class="role-org">{item.organisation}</span></> : null}
                {location ? <> · <span class="role-location">{location}</span></> : null}
              </div>
              {(item.startDate || item.endDate) ? (
                <time class="role-dates">
                  {item.startDate}
                  {item.startDate && item.endDate ? " — " : ""}
                  {item.current ? "Present" : item.endDate}
                </time>
              ) : null}
            </div>

            {/* Render summary only if it exists and is not empty */}
            {item.summary && item.summary.trim().length > 0 && <p>{item.summary}</p>}

            {/* Details dropdown only renders if there is related content */}
            {hasMoreDetail(item) ? (
              <details class="more-detail">
                <summary>More detail</summary>
                
                {item.relatedAwards && item.relatedAwards.length > 0 && (
                  <>
                    <h4 class="role-subheading">Awards</h4>
                    <ul class="role-list">
                      {item.relatedAwards.map((id) => {
                        const a = awardMap.get(id);
                        return a ? (
                          <li>
                            <strong>{a.title}</strong>
                            {a.issuer ? <> · {a.issuer}</> : null}
                          </li>
                        ) : null;
                      })}
                    </ul>
                  </>
                )}

                {item.projects && item.projects.length > 0 && (
                  <>
                    <h4 class="role-subheading">Projects</h4>
                    <ul class="role-list">
                      {item.projects.map((slug) => {
                        const p = projectMap.get(slug);
                        return (
                          <li>
                            <a href={`https://rjmlaird.co.uk/projects/${slug}`} target="_blank" rel="noopener noreferrer">
                              {p?.title ?? slug}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </>
                )}
              </details>
            ) : null}
          </article>
        );
      })
    ) : (
      <p>No volunteering records found.</p>
    )}
  </div>
</section>