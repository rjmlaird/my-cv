---
import { volunteering } from '@/data/volunteering';
---

<section id="volunteering" aria-labelledby="volunteering-heading">
  <p class="eyebrow">Community</p>
  <h2 id="volunteering-heading">Volunteering</h2>
  <div class="cert-grid">
    {volunteering.map((group) => (
      <div class="cert-group">
        <h3>{group.title}</h3>
        <ul>{group.items.map((item) => <li>{item}</li>)}</ul>
      </div>
    ))}
  </div>
</section>