---
import * as api from "@/lib/api";
import { aggregateSkills, type SkillSource } from "@/lib/skills";

// Fetch data
const [
  experience,
  education,
  certifications,
  memberships,
  awards,
  volunteering,
  languages,
  profile,
] = await Promise.all([
  api.getExperience(),
  api.getEducation(),
  api.getCertifications(),
  api.getMemberships(),
  api.getAwards(),
  api.getVolunteering(),
  api.getLanguages(),
  api.getProfile(),
]);

// Skills
const skillSources: SkillSource[] = [
  ...experience.map((role) => ({ 
    tags: role.skills ?? [], 
    ref: { label: role.role, href: `#exp-${role.id}` } 
  })),
  ...education.map((item) => ({
    tags: item.skills ?? [],
    ref: { label: item.qualification || item.role || "Education", href: `#edu-${item.id}` },
  })),
];

const skillsFlat = (await aggregateSkills(skillSources)).map((s) => s.label).join(", ");

// Flattening Helpers (Safe Version)
const certsFlat = (certifications ?? [])
  .map((c: any) => [c.name, c.issuer ? `— ${c.issuer}` : "", c.type ? `(${c.type})` : ""].filter(Boolean).join(" "))
  .filter(Boolean)
  .join(". ");

// Fixed groupFlat: Added defensive defaults
const groupFlat = (data: any[]) => 
  (data ?? [])
    .map((g) => {
      const items = Array.isArray(g.items) ? g.items : [];
      const itemStrings = items
        .map((i: any) => [i.organisation, i.role].filter(Boolean).join(" — "))
        .filter(Boolean)
        .join(", ");
      return itemStrings ? `${g.title}: ${itemStrings}` : "";
    })
    .filter(Boolean)
    .join(". ");

const membershipsFlat = groupFlat(memberships);
const volunteeringFlat = groupFlat(volunteering);

const languagesFlat = (languages ?? [])
  .map((l: any) => `${l.name}${l.level ? ` (${l.level})` : ""}`)
  .join("; ");
---

<main id="ats-view">
  <header>
    <h1>{profile.preferredName || profile.name}</h1>
    <p class="ats-meta">
      {profile.role} · {profile.credentials}<br />
      Email: {profile.email} | {profile.contact?.map(c => `${c.label}: ${c.href}`).join(" | ")}
    </p>
  </header>

  <section aria-labelledby="summary-heading">
    <h2 id="summary-heading">Summary</h2>
    {profile.summary?.map((p) => <p>{p}</p>)}
  </section>

  <section aria-labelledby="skills-heading">
    <h2 id="skills-heading">Skills</h2>
    <p>{profile.tags?.join(", ")}. Technical: {skillsFlat}.</p>
  </section>

  <section aria-labelledby="experience-heading">
    <h2 id="experience-heading">Experience</h2>
    {experience.map((role) => (
      <article id={`exp-${role.id}`}>
        <h3>{role.role}</h3>
        <p class="ats-meta">
          {role.organisation || "Self-employed"} · {role.startDate} {role.current ? "to present" : role.endDate ? `to ${role.endDate}` : ""}
        </p>
        {role.summary && <p>{role.summary}</p>}
        {role.responsibilities?.length > 0 && (
          <ul>
            {role.responsibilities.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </article>
    ))}
  </section>

  <section aria-labelledby="education-heading">
    <h2 id="education-heading">Education</h2>
    <ul>
      {education.map((item) => (
        <li id={`edu-${item.id}`}>
          <strong>{item.qualification}</strong> — {item.institution}
          {item.field && `, ${item.field}`}
          {item.startDate && ` (${item.startDate}${item.endDate ? ` – ${item.endDate}` : ""})`}
        </li>
      ))}
    </ul>
  </section>

  <section aria-labelledby="certifications-heading">
    <h2 id="certifications-heading">Certifications</h2>
    <p>{certsFlat}</p>
  </section>

  <section aria-labelledby="memberships-heading">
    <h2 id="memberships-heading">Memberships</h2>
    <p>{membershipsFlat}</p>
  </section>

  <section aria-labelledby="languages-heading">
    <h2 id="languages-heading">Languages</h2>
    <p>{languagesFlat}</p>
  </section>

  <section aria-labelledby="volunteering-heading">
    <h2 id="volunteering-heading">Volunteering</h2>
    <p>{volunteeringFlat}</p>
  </section>

  <section aria-labelledby="awards-heading">
    <h2 id="awards-heading">Awards</h2>
    <p>{awards.map(a => `${a.title} ${a.issuer ? `— ${a.issuer}` : ""} (${a.year})`).join("; ")}</p>
  </section>
</main>