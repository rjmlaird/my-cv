---
import api from "@/lib/api";
import { aggregateSkills, type SkillSource, type AggregatedSkill } from "@/lib/skills";
import type { CertificationItem } from "@/lib/schemas/certification.schema";
import type { MembershipGroup } from "@/lib/schemas/membership.schema";

// Fetch all data with default empty arrays to prevent failures
const [
  experience = [],
  education = [],
  certifications = [],
  memberships = [],
] = await Promise.all([
  api.getExperience(),
  api.getEducation(),
  api.getCertifications(),
  api.getMemberships(),
]);

const _sortByDate = <T extends { startDate?: string | null }>(arr: T[]) => 
  [...(arr ?? [])].sort((a, b) => 
    new Date(b.startDate ?? 0).getTime() - new Date(a.startDate ?? 0).getTime()
  );

const sortedExperience = _sortByDate(experience);
const sortedEducation = _sortByDate(education);

// Skill aggregation with safety checks
const skillSources: SkillSource[] = [
  ...experience.map((r: any) => ({ tags: r.skills ?? [], ref: { label: r.role, href: "" } })),
  ...education.map((e: any) => ({ tags: e.skills ?? [], ref: { label: e.qualification || "", href: "" } })),
];

const allSkills = skillSources.length > 0 ? await aggregateSkills(skillSources) : [];
const skillsFlat = (allSkills as AggregatedSkill[])
  .filter((s: any) => (s.references?.length ?? 0) > 1)
  .map((s: any) => s.label)
  .join(", ");

// Grouping with safety checks
const groupedCerts = certifications.reduce((acc: Record<string, CertificationItem[]>, c: CertificationItem) => {
  if (!c.issuer) return acc;
  acc[c.issuer] = acc[c.issuer] || [];
  acc[c.issuer].push(c);
  return acc;
}, {} as Record<string, CertificationItem[]>);

const groupedMemberships = memberships.reduce((acc: Record<string, MembershipGroup[]>, g: MembershipGroup) => {
  const title = g.title || "General Membership";
  acc[title] = acc[title] || [];
  acc[title].push(g);
  return acc;
}, {} as Record<string, MembershipGroup[]>);
---

<main>
  {skillsFlat && (
    <section>
      <h2>Skills</h2>
      <p>{skillsFlat}</p>
    </section>
  )}

  {sortedExperience.length > 0 && (
    <section>
      <h2>Experience</h2>
      <ul>
        {sortedExperience.map((exp: any) => <li>{exp.role} at {exp.organisation}</li>)}
      </ul>
    </section>
  )}

  {sortedEducation.length > 0 && (
    <section>
      <h2>Education</h2>
      <ul>
        {sortedEducation.map((edu: any) => <li>{edu.qualification}</li>)}
      </ul>
    </section>
  )}

  {Object.keys(groupedCerts).length > 0 && (
    <section>
      <h2>Certifications</h2>
      {Object.entries(groupedCerts).map(([issuer, certs]) => (
        <div>
          <h3>{issuer}</h3>
          <ul>
            {certs.map((c) => <li>{c.name}</li>)}
          </ul>
        </div>
      ))}
    </section>
  )}

  {Object.keys(groupedMemberships).length > 0 && (
    <section>
      <h2>Memberships</h2>
      {Object.entries(groupedMemberships).map(([title, groups]) => (
        <div>
          <h3>{title}</h3>
          <ul>
            {(groups as MembershipGroup[]).flatMap((g: MembershipGroup) => 
              g.items.map((i: any) => <li>{i.organisation}</li>)
            )}
          </ul>
        </div>
      ))}
    </section>
  )}
</main>