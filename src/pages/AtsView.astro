---
// Optimized for machine parsing (ATS/Screen Readers)
import api from "@/lib/api";
import { aggregateSkills, type SkillSource } from "@/lib/skills";
import { joinParts } from "@/lib/format";

// Data fetching
const [profile, experience, education, certifications, membershipGroups, awards, languages, volunteering, socials] = await Promise.all([
  api.getProfile(), api.getExperience(), api.getEducation(), api.getCertifications(), 
  api.getMemberships(), api.getAwards(), api.getLanguages(), api.getVolunteering(), api.getSocials(),
]);

// Helpers
const formatATSDate = (d: string | null | undefined) => d ? new Date(d).toISOString().slice(0, 7) : "";
const sortDesc = <T extends { startDate?: string | null }>(arr: T[]) => 
  [...arr].sort((a, b) => new Date(b.startDate ?? 0).getTime() - new Date(a.startDate ?? 0).getTime());

const getLoc = (item: any) => joinParts([item.city || item.location?.city, item.country || item.location?.country], ", ");

const sortedExp = sortDesc(experience);
const sortedEdu = sortDesc(education);
const sortedVol = sortDesc(volunteering);

const groupedCerts = certifications.reduce((acc: Record<string, any[]>, c) => {
  if (!c.issuer) return acc;
  acc[c.issuer] = acc[c.issuer] || [];
  acc[c.issuer].push(c);
  return acc;
}, {});

const skillSources: SkillSource[] = [
  ...experience.map(r => ({ tags: r.skills ?? [], ref: { label: r.role, href: "" } })),
  ...education.map(e => ({ tags: e.skills ?? [], ref: { label: e.qualification || "", href: "" } })),
];
const allSkills = await aggregateSkills(skillSources);
const skillsFlat = allSkills.map((s: any) => s.label).join(", ");

// Safely extract summary to avoid TS errors
const summary = profile?.summary ?? [];
---

<main id="ats-view" style="font-family: sans-serif; line-height: 1.5; color: #000; max-width: 800px; margin: auto;">
  <header>
    <h1>{profile?.name ?? "Ryan Laird"}</h1>
    <p><strong>{profile?.role}</strong></p>
  </header>

  {summary.length > 0 && (
    <section>
      <h2>Professional Summary</h2>
      {summary.map(p => <p>{p}</p>)}
    </section>
  )}

  {skillsFlat && (
    <section>
      <h2>Skills & Technical Competencies</h2>
      <p>{skillsFlat}</p>
    </section>
  )}

  {sortedExp.length > 0 && (
    <section>
      <h2>Professional Experience</h2>
      {sortedExp.map(exp => (
        <article style="margin-bottom: 1.5em;">
          <h3>{exp.role} — {typeof exp.organisation === "string" ? exp.organisation : exp.organisation?.name}</h3>
          <p><strong>{getLoc(exp)}</strong> | {formatATSDate(exp.startDate)} to {exp.current ? "Present" : formatATSDate(exp.endDate)}</p>
          {exp.summary && <p>{exp.summary}</p>}
          <ul>
            {exp.responsibilities?.map((r: string) => <li>{r}</li>)}
            {exp.achievements?.map((a: string) => <li>Achievement: {a}</li>)}
          </ul>
          {exp.technologies?.length > 0 && <p><strong>Stack:</strong> {exp.technologies.join(", ")}</p>}
        </article>
      ))}
    </section>
  )}

  {sortedEdu.length > 0 && (
    <section>
      <h2>Education</h2>
      {sortedEdu.map(edu => (
        <article style="margin-bottom: 1em;">
          <h3>{edu.qualification}{edu.field ? ` — ${edu.field}` : ""}</h3>
          <p><strong>{getLoc(edu)}</strong> | {edu.institution} | {formatATSDate(edu.startDate)} to {formatATSDate(edu.endDate)}</p>
        </article>
      ))}
    </section>
  )}

  {Object.keys(groupedCerts).length > 0 && (
    <section>
      <h2>Certifications</h2>
      {Object.entries(groupedCerts).map(([issuer, certs]: [string, any]) => (
        <div style="margin-bottom: 0.5em;">
          <strong>{issuer}</strong>
          <ul>
            {certs.map((c: any) => <li>{c.name} {c.level ? `(${c.level})` : ""}</li>)}
          </ul>
        </div>
      ))}
    </section>
  )}

  {sortedVol.length > 0 && (
    <section>
      <h2>Volunteering</h2>
      {sortedVol.map(v => (
        <article style="margin-bottom: 0.5em;">
          <p><strong>{v.role}</strong> — {v.organisation} | <strong>{getLoc(v)}</strong> | {formatATSDate(v.startDate)} to {v.current ? "Present" : formatATSDate(v.endDate)}</p>
        </article>
      ))}
    </section>
  )}

  <section>
    <h2>Contact</h2>
    <p>Email: {profile?.email ?? "N/A"}</p>
    <p>Location: {profile?.location ?? "N/A"}</p>
  </section>
</main>