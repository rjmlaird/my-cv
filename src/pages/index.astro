---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Hero from "@/components/Hero.astro";
import Experience from "@/components/Experience.astro";
import Education from "@/components/Education.astro";
import Certifications from "@/components/Certifications.astro";
import Memberships from "@/components/Memberships.astro";
import Languages from "@/components/Languages.astro";
import Research from "@/components/Research.astro";
import Awards from "@/components/Awards.astro";
import Skills from "@/components/Skills.astro";
import Volunteering from "@/components/Volunteering.astro";
import Contact from "@/components/Contact.astro";
import Footer from "@/components/Footer.astro";
import AtsView from "./AtsView.astro";
---

<Layout>
  <Nav />
  <Hero />

  <main id="about">
    <Experience />
    <Education />
    <Research />
    <Certifications />
    <Memberships />
    <Languages />
    <Awards />
    <Skills />
    <Volunteering />
    <Contact />
  </main>

  <Footer />
  <AtsView />
</Layout>
