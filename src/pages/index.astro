---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Hero from "@/components/Hero.astro";
import Experience from "@/components/Experience.astro";
import Education from "@/components/Education.astro";
import Certifications from "@/components/Certifications.astro";
import Memberships from "@/components/Memberships.astro";
import Languages from "@/components/Languages.astro";
import Research from "@/components/Research.astro";
import Awards from "@/components/Awards.astro";
import Skills from "@/components/Skills.astro";
import Tools from '@/components/Tools.astro';
import Volunteering from "@/components/Volunteering.astro";
import Contact from "@/components/Contact.astro";
import Footer from "@/components/Footer.astro";
import AtsView from "./AtsView.astro";
import api from "@/lib/api";
import { aggregateSkills, type SkillSource } from "@/lib/skills";
import { buildStructuredData } from "@/lib/structuredData";

// Fetch all data with individual error handling
const [
  profile,
  experience,
  education,
  certifications,
  membershipGroups,
  awards,
  languages,
  socials,
  tools, 
  volunteering,
  projects,
] = await Promise.all([
  api.getProfile().catch((e) => { console.error("[CRITICAL] Profile fetch failed:", e); return null; }),
  api.getExperience().catch(() => []),
  api.getEducation().catch(() => []),
  api.getCertifications().catch(() => []),
  api.getMemberships().catch(() => []),
  api.getAwards().catch(() => []),
  api.getLanguages().catch(() => []),
  api.getSocials().catch(() => []),
  api.getTools().catch(() => ({ categories: [] })),
  api.getVolunteering().catch(() => []),
  api.getProjects().catch(() => []),
]);

// Prepare Skill Data
const skillSources: SkillSource[] = [
  ...experience.map((r) => ({ tags: r.skills ?? [], ref: { label: r.role, href: "" } })),
  ...education.map((e) => ({ tags: e.skills ?? [], ref: { label: e.qualification || "", href: "" } })),
];
const aggregatedSkills = skillSources.length > 0 ? await aggregateSkills(skillSources) : [];
const skillLabels = aggregatedSkills.map((s) => s.label);

// Meta & Structured Data
const siteUrl = (Astro.site ?? new URL("https://cv.rjmlaird.co.uk")).origin;
const ogImageUrl = new URL("/og-image.png", siteUrl).toString();

const structuredData = buildStructuredData({
  siteUrl,
  ogImageUrl,
  profile,
  experience,
  education,
  certifications,
  memberships: Array.isArray(membershipGroups) ? membershipGroups : [],
  awards,
  languages,
  socials,
  skillLabels,
});
---

<Layout structuredData={structuredData}>
  <Nav />
  
  <Hero profile={profile} />
  
  <main id="main-content" aria-label="CV content">
    <Experience experience={experience} />
    <Education education={education} />
    <Research socials={socials} />
    <Certifications certifications={certifications} />
    <Memberships memberships={membershipGroups} />
    <Languages languages={languages} />
    <Awards awards={awards} />
    <Skills skills={skillLabels} />
    <Tools data={tools} />
    <Volunteering 
      volunteering={volunteering} 
      allProjects={projects} 
      allAwards={awards} 
      allCertifications={certifications} 
    />
    <Contact profile={profile} socials={socials} />
  </main>

  <Footer />
  <AtsView />
</Layout>